page {
  min-height: 100%;
  background: #080b10;
  color: #fff8ed;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

.legal-page {
  min-height: 100vh;
  background:
    radial-gradient(circle at 16% -8%, rgba(226, 178, 99, 0.2), transparent 34%),
    radial-gradient(circle at 86% 12%, rgba(91, 212, 199, 0.13), transparent 30%),
    linear-gradient(180deg, #080b10 0%, #0b0d12 100%);
}

.status-bar {
  height: 44rpx;
}

.legal-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  height: 92rpx;
  padding: 0 28rpx;
  color: #fff8ed;
  font-size: 30rpx;
  font-weight: 900;
}

.back-button {
  width: 54rpx;
  height: 54rpx;
  color: #071311;
  font-size: 50rpx;
  line-height: 46rpx;
  text-align: center;
  background: linear-gradient(135deg, #d7fb52, #5bd4c7);
  border-radius: 999rpx;
}

.legal-scroll {
  height: calc(100vh - 136rpx);
}

.legal-content {
  padding: 32rpx 32rpx calc(72rpx + env(safe-area-inset-bottom));
}

.legal-title {
  display: block;
  color: #fff8ed;
  font-size: 48rpx;
  font-weight: 900;
  line-height: 1.15;
}

.legal-updated {
  display: block;
  margin-top: 14rpx;
  color: rgba(245, 240, 232, 0.56);
  font-size: 22rpx;
}

.legal-section {
  margin-top: 36rpx;
  padding-top: 30rpx;
  border-top: 1rpx solid rgba(255, 255, 255, 0.1);
}

.section-title,
.section-text {
  display: block;
}

.section-title {
  color: #d7fb52;
  font-size: 30rpx;
  font-weight: 900;
}

.section-text {
  margin-top: 18rpx;
  color: rgba(245, 240, 232, 0.78);
  font-size: 26rpx;
  line-height: 1.7;
}
