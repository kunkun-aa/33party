.legal-page {
  --page-bg: #0a0c10;
  --page-bg-2: #11141a;
  --text-strong: #f8fbff;
  --text: rgba(248, 251, 255, 0.86);
  --text-muted: rgba(222, 230, 240, 0.58);
  --glass: rgba(24, 28, 36, 0.64);
  --glass-soft: rgba(255, 255, 255, 0.07);
  --hairline: rgba(255, 255, 255, 0.12);
  --accent: #64d7f2;
  --accent-2: #ffd166;
  --accent-3: #9cff6d;
  --shadow-soft: 0 18rpx 50rpx rgba(0, 0, 0, 0.28);
  min-height: 100vh;
  color: var(--text);
  background:
    radial-gradient(circle at 16% -8%, rgba(100, 215, 242, 0.18), transparent 34%),
    radial-gradient(circle at 86% 12%, rgba(255, 209, 102, 0.14), transparent 30%),
    linear-gradient(180deg, var(--page-bg) 0%, var(--page-bg-2) 100%);
}

.legal-page.theme-light {
  --page-bg: #eff5fb;
  --page-bg-2: #fbfdff;
  --text-strong: #17202b;
  --text: rgba(23, 32, 43, 0.84);
  --text-muted: rgba(61, 75, 94, 0.58);
  --glass: rgba(255, 255, 255, 0.74);
  --glass-soft: rgba(255, 255, 255, 0.58);
  --hairline: rgba(80, 103, 132, 0.16);
  --shadow-soft: 0 18rpx 48rpx rgba(83, 103, 132, 0.16);
  background:
    radial-gradient(circle at 16% -8%, rgba(100, 215, 242, 0.26), transparent 34%),
    radial-gradient(circle at 86% 12%, rgba(255, 209, 102, 0.22), transparent 30%),
    linear-gradient(180deg, var(--page-bg) 0%, var(--page-bg-2) 100%);
}

.status-bar {
  height: 44rpx;
}

.legal-nav {
  display: flex;
  align-items: center;
  gap: 18rpx;
  height: 96rpx;
  margin: 0 24rpx;
  padding: 0 18rpx;
  color: var(--text-strong);
  font-size: 30rpx;
  font-weight: 900;
  background: var(--glass);
  border: 1rpx solid var(--hairline);
  border-radius: 24rpx;
  box-shadow: var(--shadow-soft);
}

.back-button {
  width: 56rpx;
  height: 56rpx;
  color: var(--page-bg);
  font-size: 50rpx;
  line-height: 48rpx;
  text-align: center;
  background: linear-gradient(135deg, var(--accent-3), var(--accent));
  border-radius: 999rpx;
}

.legal-scroll {
  height: calc(100vh - 140rpx);
}

.legal-content {
  padding: 34rpx 32rpx calc(72rpx + env(safe-area-inset-bottom));
}

.legal-title {
  display: block;
  color: var(--text-strong);
  font-size: 50rpx;
  font-weight: 900;
  line-height: 1.14;
}

.legal-updated {
  display: block;
  margin-top: 14rpx;
  color: var(--text-muted);
  font-size: 22rpx;
}

.legal-section {
  margin-top: 28rpx;
  padding: 26rpx;
  background: var(--glass);
  border: 1rpx solid var(--hairline);
  border-radius: 24rpx;
  box-shadow: var(--shadow-soft);
}

.section-title,
.section-text {
  display: block;
}

.section-title {
  color: var(--accent-3);
  font-size: 30rpx;
  font-weight: 900;
}

.section-text {
  margin-top: 18rpx;
  color: var(--text);
  font-size: 26rpx;
  line-height: 1.72;
}
