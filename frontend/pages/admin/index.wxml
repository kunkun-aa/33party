<view class="admin-page theme-{{theme}}">
  <view class="ambient ambient-lime"></view>
  <view class="ambient ambient-cyan"></view>

  <view class="top-panel" style="margin-top: {{topSafeArea}}px;">
    <view class="top-row">
      <view>
        <view class="title">现场桌房总览</view>
      </view>
      <view class="top-actions">
        <view class="icon-button icon-only {{refreshing ? 'refreshing' : ''}}" bindtap="refreshData" aria-label="刷新">
          <t-icon name="refresh" size="28rpx" />
        </view>
        <view class="theme-toggle" bindtap="toggleTheme" aria-label="切换主题">
          <t-icon name="{{theme === 'dark' ? 'moon' : 'sunny'}}" size="28rpx" />
        </view>
      </view>
    </view>

    <view class="metrics">
      <view class="metric">
        <text class="metric-value">{{tables.length}}</text>
        <text class="metric-label">桌/房</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{stats.onlineMembers}}</text>
        <text class="metric-label">在线成员</text>
      </view>
      <view class="metric">
        <text class="metric-value">{{stats.photoCount}}</text>
        <text class="metric-label">照片</text>
      </view>
      <view class="metric alert">
        <text class="metric-value">{{stats.attentionCount}}</text>
        <text class="metric-label">需关注</text>
      </view>
    </view>
  </view>

  <view class="filter-tabs">
    <view class="filter-tab {{filter === 'all' ? 'active' : ''}}" data-filter="all" bindtap="setFilter">全部</view>
    <view class="filter-tab {{filter === 'available' ? 'active' : ''}}" data-filter="available" bindtap="setFilter">人数未满</view>
    <view class="filter-tab {{filter === 'full' ? 'active' : ''}}" data-filter="full" bindtap="setFilter">人数已满</view>
    <view class="filter-tab {{filter === 'attention' ? 'active' : ''}}" data-filter="attention" bindtap="setFilter">需关注</view>
    <view class="filter-tab {{filter === 'ended' ? 'active' : ''}}" data-filter="ended" bindtap="setFilter">已结束</view>
  </view>

  <view class="ops-panel">
    <view class="ops-card">
      <view class="ops-head">
        <view>
          <view class="ops-icon-title">
            <t-icon name="user" size="28rpx" />
            <text class="ops-title">管理员微信</text>
          </view>
        </view>
        <view class="ops-button icon-submit {{copiedText === 'admin_wechat_saved' ? 'copied' : ''}} {{wechatSaving ? 'loading' : ''}}" bindtap="saveAdminWechat" aria-label="保存管理员微信">
          <t-icon name="{{copiedText === 'admin_wechat_saved' ? 'check' : 'save'}}" size="28rpx" />
        </view>
      </view>
      <view class="field-shell">
        <t-icon name="user" size="24rpx" />
        <t-input t-class="ops-input" t-class-input="ops-input-control" value="{{wechatDraft}}" bind:change="onWechatDraftInput" placeholder="输入管理员微信号" placeholder-class="ops-placeholder" borderless />
      </view>
    </view>

    <view class="ops-card create-card">
      <view class="ops-head">
        <view>
          <view class="ops-icon-title">
            <t-icon name="add-circle" size="28rpx" />
            <text class="ops-title">创建新局</text>
          </view>
        </view>
        <view class="ops-button icon-submit {{copiedText === 'party_created' ? 'copied' : ''}} {{creatingParty ? 'loading' : ''}}" bindtap="createParty" aria-label="创建新局">
          <t-icon name="{{copiedText === 'party_created' ? 'check' : 'check-circle'}}" size="28rpx" />
        </view>
      </view>
      <view class="create-form">
        <view class="form-item">
          <view class="field-shell">
            <t-icon name="flag" size="24rpx" />
            <t-input t-class="ops-input" t-class-input="ops-input-control" data-field="title" value="{{createForm.title}}" bind:change="onCreateFormInput" placeholder="局名称" placeholder-class="ops-placeholder" borderless />
          </view>
        </view>
        <view class="form-row">
          <view class="form-item">
            <view class="field-shell">
              <t-icon name="location" size="24rpx" />
              <t-input t-class="ops-input" t-class-input="ops-input-control" data-field="tableNo" value="{{createForm.tableNo}}" bind:change="onCreateFormInput" placeholder="桌号 / 房号" placeholder-class="ops-placeholder" borderless />
            </view>
          </view>
          <view class="form-item form-item-small">
            <view class="field-shell">
              <t-icon name="user" size="24rpx" />
              <t-input t-class="ops-input" t-class-input="ops-input-control" type="number" data-field="capacity" value="{{createForm.capacity}}" bind:change="onCreateFormInput" placeholder="人数" placeholder-class="ops-placeholder" borderless />
            </view>
          </view>
        </view>
        <view class="form-item">
          <view class="field-shell">
            <t-icon name="time" size="24rpx" />
            <t-input t-class="ops-input" t-class-input="ops-input-control" data-field="startsAt" value="{{createForm.startsAt}}" bind:change="onCreateFormInput" placeholder="2026-06-02 21:00" placeholder-class="ops-placeholder" borderless />
          </view>
        </view>
        <view class="form-item">
          <view class="field-shell">
            <t-icon name="shop" size="24rpx" />
            <t-input t-class="ops-input" t-class-input="ops-input-control" data-field="barName" value="{{createForm.barName}}" bind:change="onCreateFormInput" placeholder="酒吧名称" placeholder-class="ops-placeholder" borderless />
          </view>
        </view>
        <view class="form-item">
          <view class="field-shell address-shell">
            <t-icon name="map-location" size="24rpx" />
            <t-input t-class="ops-input" t-class-input="ops-input-control" data-field="barAddress" value="{{createForm.barAddress}}" bind:change="onCreateFormInput" placeholder="详细地址" placeholder-class="ops-placeholder" borderless />
            <view class="location-action icon-only" bindtap="chooseBarLocation" aria-label="地图选点">
              <t-icon name="{{createForm.latitude && createForm.longitude ? 'check' : 'map-search'}}" size="24rpx" />
            </view>
          </view>
          <text class="location-state">{{createForm.latitude && createForm.longitude ? '已确认地图坐标' : '用户端地图需要先确认坐标'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="reports-panel">
    <view class="reports-head">
      <view>
        <text class="ops-title">举报处理</text>
      </view>
      <text class="report-count" wx:if="{{reportLoading}}">加载中</text>
      <text class="report-count" wx:else>{{reports.length}} 条</text>
    </view>
    <view class="report-tabs">
      <view
        wx:for="{{reportFilters}}"
        wx:key="key"
        class="report-tab {{reportFilter === item.key ? 'active' : ''}}"
        data-filter="{{item.key}}"
        bindtap="setReportFilter"
        aria-label="{{item.key === 'pending' ? '待处理' : item.key === 'resolved' ? '已处理' : '已驳回'}}"
      >{{item.label}}</view>
    </view>
    <view class="report-list" wx:if="{{reports.length}}">
      <view class="report-card" wx:for="{{reports}}" wx:key="id">
        <view class="report-top">
          <view>
            <text class="report-reason">{{item.reason}}</text>
            <text class="report-meta">{{item.tableNo}} · {{item.createdText}}</text>
          </view>
          <text class="report-status {{item.status}}" aria-label="{{item.status === 'pending' ? '待处理' : item.status === 'resolved' ? '已处理' : '已驳回'}}">{{item.status === 'pending' ? '!' : item.status === 'resolved' ? '✓' : '×'}}</text>
        </view>
        <text class="report-line">举报人：{{item.reporterName}}</text>
        <text class="report-line">对象：{{item.targetType === 'message' ? '消息' : '用户'}} {{item.targetUserName || item.targetUserId}}</text>
        <text class="report-message" wx:if="{{item.targetMessage}}">{{item.targetMessage.text}}</text>
        <view class="report-actions">
          <button
            wx:if="{{item.targetType === 'message' && item.targetMessage && !item.targetMessage.isDeleted}}"
            class="mini-action icon-action"
            data-message-id="{{item.targetId}}"
            bindtap="deleteReportMessage"
            aria-label="删除消息"
          ><t-icon name="delete" size="24rpx" /></button>
          <button
            wx:if="{{item.targetUserId && !item.targetUserBannedAt}}"
            class="mini-action danger icon-action"
            data-user-id="{{item.targetUserId}}"
            data-name="{{item.targetUserName}}"
            bindtap="banReportUser"
            aria-label="封禁用户"
          ><t-icon name="lock-on" size="24rpx" /></button>
          <button
            wx:if="{{item.targetUserId && item.targetUserBannedAt}}"
            class="mini-action icon-action"
            data-user-id="{{item.targetUserId}}"
            data-name="{{item.targetUserName}}"
            bindtap="unbanReportUser"
            aria-label="解除封禁"
          ><t-icon name="lock-off" size="24rpx" /></button>
          <button
            wx:if="{{item.targetMemberId}}"
            class="mini-action icon-action"
            data-member-id="{{item.targetMemberId}}"
            data-name="{{item.targetUserName}}"
            bindtap="kickReportMember"
            aria-label="移除成员"
          ><t-icon name="user-clear" size="24rpx" /></button>
          <button wx:if="{{item.status === 'pending'}}" class="mini-action icon-action" data-report-id="{{item.id}}" data-status="resolved" bindtap="resolveReport" aria-label="标记已处理"><t-icon name="check" size="24rpx" /></button>
          <button wx:if="{{item.status === 'pending'}}" class="mini-action muted-action icon-action" data-report-id="{{item.id}}" data-status="rejected" bindtap="resolveReport" aria-label="驳回举报"><t-icon name="close" size="24rpx" /></button>
        </view>
      </view>
    </view>
    <view class="report-empty" wx:else>{{reportLoading ? '正在加载举报记录' : '暂无该状态举报'}}</view>
  </view>

  <view class="ended-panel" wx:if="{{endedTables.length}}">
    <view class="reports-head">
        <view>
          <text class="ops-title">已结束局</text>
        </view>
      <button class="mini-action danger icon-action {{deletingParties ? 'loading' : ''}}" bindtap="deleteSelectedEndedParties" aria-label="删除选中">
        <t-icon name="delete" size="24rpx" />
      </button>
    </view>
    <view class="ended-list">
      <view
        wx:for="{{endedTables}}"
        wx:key="partyId"
        class="ended-row {{item.deleteSelected ? 'selected' : ''}}"
        data-party-id="{{item.partyId}}"
        bindtap="toggleEndedParty"
      >
        <view class="ended-check">{{item.deleteSelected ? '✓' : ''}}</view>
        <view class="ended-copy">
          <text class="ended-title">{{item.title || currentParty.title || createForm.title}}</text>
          <text class="ended-meta">{{item.tableNo}} · {{item.startsAtText || '未设置时间'}}</text>
        </view>
      </view>
    </view>
  </view>

  <view class="content-grid">
    <view class="table-list">
      <block wx:for="{{visibleTables}}" wx:key="id">
        <view
          class="table-card {{selectedId === item.id ? 'selected' : ''}}"
          data-id="{{item.id}}"
          bindtap="selectTable"
        >
          <view class="card-head">
            <view>
              <text class="table-no">{{item.title || currentParty.title || createForm.title}}</text>
              <text class="room-name">{{item.tableNo}}</text>
            </view>
            <view class="card-actions">
              <text class="status-pill {{item.status}}">{{item.statusText}}</text>
              <view class="panel-icon-button room-entry-button" data-id="{{item.id}}" catchtap="enterSelectedRoomAsAdmin" aria-label="管理员进房间">
                <t-icon name="login" size="24rpx" />
              </view>
            </view>
          </view>

          <view class="card-main">
            <view class="count-block">
              <text class="count">{{item.memberCount}}</text>
              <text class="capacity">/{{item.capacity}} 人</text>
            </view>
            <view class="head-block">
              <text class="muted">局头</text>
              <text class="head-name">{{item.head || '未指定'}}</text>
            </view>
            <view class="activity">
              <text>{{item.messageCount}} 消息</text>
              <text>{{item.photoCount}} 照片</text>
            </view>
          </view>

          <view class="seat-line">
            <view class="seat-progress">
              <view class="seat-progress-fill" style="transform: scaleX({{item.capacity ? item.memberCount / item.capacity : 0}});"></view>
            </view>
            <text>占位 {{item.memberCount}}/{{item.capacity}}</text>
            <text class="{{(item.ghostCount || 0) > 0 ? 'attention-text' : ''}}">未占位 {{item.ghostCount || 0}}</text>
          </view>

          <view class="avatars">
            <block wx:for="{{item.members}}" wx:for-item="member" wx:key="name">
              <t-avatar
                t-class="avatar {{member.online ? 'online' : ''}}"
                size="52rpx"
                shape="round"
                image="{{member.avatarUrl}}"
                custom-style="background: {{member.avatarColor}}; color: #ffffff;"
              >{{member.avatarText}}</t-avatar>
            </block>
          </view>

          <view class="last-line">
            <text>{{item.lastMessage}}</text>
            <text class="time">{{item.updatedAt}}</text>
          </view>
        </view>
      </block>
    </view>

    <view wx:if="{{selectedTable}}" class="detail-panel">
      <view class="detail-head">
        <view>
          <text class="detail-kicker">{{selectedTable.tableNo}}</text>
          <view class="detail-title">{{selectedTable.title || currentParty.title || createForm.title}}</view>
        </view>
        <view class="detail-actions">
          <text class="status-pill {{selectedTable.status}}">{{selectedTable.memberCount}}/{{selectedTable.capacity}}</text>
          <view class="panel-icon-button {{savingParty ? 'loading' : ''}}" bindtap="saveSelectedParty" aria-label="保存局信息">
            <t-icon name="{{savingParty ? 'loading' : 'save'}}" size="24rpx" />
          </view>
          <view class="panel-icon-button" bindtap="enterSelectedRoomAsAdmin" aria-label="管理员进房间">
            <t-icon name="login" size="24rpx" />
          </view>
          <view wx:if="{{selectedTable.status !== 'ended'}}" class="panel-icon-button danger {{endingParty ? 'loading' : ''}}" bindtap="endCurrentParty" aria-label="解散当前局">
            <t-icon name="poweroff" size="24rpx" />
          </view>
        </view>
      </view>

      <view class="edit-card">
        <view class="section-title">局信息</view>
        <view class="create-form edit-form">
          <view class="form-item">
            <view class="field-shell">
              <t-icon name="flag" size="24rpx" />
              <t-input t-class="ops-input" t-class-input="ops-input-control" data-field="title" value="{{editForm.title}}" bind:change="onEditFormInput" placeholder="局名称" placeholder-class="ops-placeholder" borderless />
            </view>
          </view>
          <view class="form-row">
            <view class="form-item">
              <view class="field-shell">
                <t-icon name="location" size="24rpx" />
                <t-input t-class="ops-input" t-class-input="ops-input-control" data-field="tableNo" value="{{editForm.tableNo}}" bind:change="onEditFormInput" placeholder="桌号 / 房号" placeholder-class="ops-placeholder" borderless />
              </view>
            </view>
            <view class="form-item form-item-small">
              <view class="field-shell">
                <t-icon name="user" size="24rpx" />
                <t-input t-class="ops-input" t-class-input="ops-input-control" type="number" data-field="capacity" value="{{editForm.capacity}}" bind:change="onEditFormInput" placeholder="人数" placeholder-class="ops-placeholder" borderless />
              </view>
            </view>
          </view>
          <view class="form-item">
            <view class="field-shell">
              <t-icon name="time" size="24rpx" />
              <t-input t-class="ops-input" t-class-input="ops-input-control" data-field="startsAt" value="{{editForm.startsAt}}" bind:change="onEditFormInput" placeholder="2026-06-02 21:00" placeholder-class="ops-placeholder" borderless />
            </view>
          </view>
          <view class="form-item">
            <view class="field-shell">
              <t-icon name="shop" size="24rpx" />
              <t-input t-class="ops-input" t-class-input="ops-input-control" data-field="barName" value="{{editForm.barName}}" bind:change="onEditFormInput" placeholder="酒吧名称" placeholder-class="ops-placeholder" borderless />
            </view>
          </view>
          <view class="form-item">
            <view class="field-shell address-shell">
              <t-icon name="map-location" size="24rpx" />
              <t-input t-class="ops-input" t-class-input="ops-input-control" data-field="barAddress" value="{{editForm.barAddress}}" bind:change="onEditFormInput" placeholder="详细地址" placeholder-class="ops-placeholder" borderless />
              <view class="location-action icon-only" bindtap="chooseEditBarLocation" aria-label="地图选点">
                <t-icon name="{{editForm.latitude && editForm.longitude ? 'check' : 'map-search'}}" size="24rpx" />
              </view>
            </view>
            <text class="location-state">{{editForm.latitude && editForm.longitude ? '已确认地图坐标' : '用户端地图需要先确认坐标'}}</text>
          </view>
        </view>
      </view>

      <view class="seat-summary">
        <view>
          <text class="seat-number">{{selectedTable.memberCount}}</text>
          <text class="seat-label">已占位</text>
        </view>
        <view>
          <text class="seat-number">{{selectedTable.ghostCount || 0}}</text>
          <text class="seat-label">未占位</text>
        </view>
        <view>
          <text class="seat-number">{{selectedTable.openSeats || 0}}</text>
          <text class="seat-label">剩余座位</text>
        </view>
      </view>

      <view class="join-box compact-action-box">
        <view>
          <text class="muted">现场拉人</text>
          <view class="join-code">小程序码优先</view>
          <text class="join-hint">{{selectedTable.tableNo}} 让玩家扫码入局，链接备用</text>
        </view>
        <view class="join-actions">
          <view class="panel-icon-button" bindtap="showJoinInfo" aria-label="打开小程序码">
            <t-icon name="qrcode" size="28rpx" />
          </view>
          <view class="panel-icon-button {{copiedText === 'join_link' ? 'copied' : ''}}" bindtap="copyJoinLink" aria-label="复制链接">
            <t-icon name="{{copiedText === 'join_link' ? 'check' : 'link'}}" size="28rpx" />
          </view>
        </view>
      </view>

      <view class="admin-wechat-box compact-action-box">
        <view>
          <text class="muted">对用户可见的管理员微信</text>
          <view class="admin-wechat">{{adminProfile.wechatId}}</view>
        </view>
        <view class="panel-icon-button {{copiedText === adminProfile.wechatId ? 'copied' : ''}}" bindtap="copyAdminWechat" aria-label="复制管理员微信">
          <t-icon name="{{copiedText === adminProfile.wechatId ? 'check' : 'copy'}}" size="28rpx" />
        </view>
      </view>

      <view class="section-title">成员</view>
      <view class="member-list">
        <block wx:for="{{selectedTable.members}}" wx:for-item="member" wx:key="name">
          <view class="member-row contact-row">
            <view class="member-main">
              <t-avatar
                t-class="avatar large {{member.online ? 'online' : ''}}"
                size="72rpx"
                shape="round"
                image="{{member.avatarUrl}}"
                custom-style="background: {{member.avatarColor}}; color: #ffffff;"
              >{{member.avatarText}}</t-avatar>
              <view class="member-meta">
                <text class="member-name">{{member.name}}</text>
                <view class="member-status-icons">
                  <view class="status-dot {{member.online ? 'online' : 'offline'}}"></view>
                  <view class="status-icon {{member.seatStatus === 'seated' ? 'seated' : 'ghost'}}">
                    <t-icon name="{{member.seatStatus === 'seated' ? 'check-circle' : 'user'}}" size="22rpx" />
                  </view>
                  <view class="status-icon gender {{member.gender}}">
                    <t-icon name="{{member.gender === 'male' ? 'gender-male' : member.gender === 'female' ? 'gender-female' : 'user-unknown'}}" size="22rpx" color="{{member.gender === 'male' ? '#2f80ff' : member.gender === 'female' ? '#ec5f9d' : '#9aa4b2'}}" />
                  </view>
                  <view wx:if="{{selectedTable.headMemberId === member.memberId}}" class="status-icon head">
                    <t-icon name="flag" size="22rpx" />
                  </view>
                </view>
                <text class="ban-tag" wx:if="{{member.bannedAt}}">已封禁</text>
                <text class="member-wechat">{{member.wechatId}}</text>
              </view>
            </view>
            <view class="contact-actions">
              <button
                class="primary-action icon-action {{copiedText === member.wechatId ? 'copied' : ''}}"
                data-name="{{member.name}}"
                data-wechat="{{member.wechatId}}"
                bindtap="contactMember"
                aria-label="复制微信"
              >
                <t-icon name="{{copiedText === member.wechatId ? 'check' : 'logo-wechat-stroke'}}" size="24rpx" />
              </button>
              <button
                class="more-action icon-action"
                data-member-id="{{member.memberId}}"
                data-user-id="{{member.id}}"
                data-name="{{member.name}}"
                data-seat-status="{{member.seatStatus}}"
                data-is-head="{{selectedTable.headMemberId === member.memberId}}"
                data-banned="{{member.bannedAt ? 'true' : 'false'}}"
                bindtap="openMemberActions"
                aria-label="成员管理"
              >
                <t-icon name="setting" size="24rpx" />
              </button>
            </view>
          </view>
        </block>
      </view>
    </view>
  </view>

  <view class="invite-mask" wx:if="{{invitePanelVisible}}" catchtap="closeInvitePanel" catchtouchmove="noop">
    <view class="invite-panel" catchtap="noop">
      <view class="invite-head">
        <view>
          <text class="muted">扫码入局</text>
          <view class="invite-title">{{inviteInfo.tableNo}} 小程序码</view>
        </view>
        <view class="invite-close" bindtap="closeInvitePanel">×</view>
      </view>

      <view class="invite-code-card">
        <view class="invite-qrcode-box">
          <image wx:if="{{inviteInfo.qrcodePath}}" class="invite-qrcode" src="{{inviteInfo.qrcodePath}}" mode="aspectFit" bindtap="previewInviteQrcode"></image>
          <view wx:elif="{{inviteLoading}}" class="invite-qrcode-placeholder">生成中</view>
          <view wx:else class="invite-qrcode-placeholder">暂无小程序码</view>
        </view>
        <text class="invite-scene">{{inviteInfo.scene}}</text>
        <text class="invite-error" wx:if="{{inviteInfo.error}}">{{inviteInfo.error}}</text>
      </view>

      <view class="invite-link-box" wx:if="{{inviteInfo.link}}">
        <text>{{inviteInfo.link}}</text>
      </view>

      <view class="invite-actions">
        <t-button t-class="invite-action" bind:click="saveInviteQrcode">保存小程序码</t-button>
        <t-button t-class="invite-action secondary" bind:click="copyInviteLink">复制链接备用</t-button>
      </view>
    </view>
  </view>
</view>
