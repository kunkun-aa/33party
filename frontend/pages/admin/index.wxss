page {
  min-height: 100%;
  background: #080b10;
  color: #eaf0f5;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Segoe UI", sans-serif;
}

.admin-page {
  position: relative;
  min-height: 100vh;
  padding: 24rpx 24rpx 56rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  background:
    radial-gradient(circle at 10% -8%, rgba(215, 251, 82, 0.16), transparent 32%),
    radial-gradient(circle at 92% 18%, rgba(0, 230, 118, 0.13), transparent 30%),
    radial-gradient(circle at 48% 70%, rgba(91, 212, 199, 0.08), transparent 34%),
    linear-gradient(180deg, #080b10 0%, #0b0d12 58%, #07090d 100%);
}

.ambient {
  position: absolute;
  width: 460rpx;
  height: 460rpx;
  border-radius: 50%;
  filter: blur(64rpx);
  opacity: 0.28;
  pointer-events: none;
  animation: adminGlow 6s ease-in-out infinite;
}

.ambient-lime {
  top: -210rpx;
  left: -190rpx;
  background: #d7fb52;
}

.ambient-cyan {
  right: -250rpx;
  top: 360rpx;
  background: #00e676;
  animation-delay: 1.3s;
}

.top-panel,
.table-card,
.detail-panel,
.ops-card,
.filter-tab,
.metric,
.seat-summary view,
.member-row,
.join-box,
.admin-wechat-box {
  background-clip: padding-box;
}

.top-panel,
.table-card,
.detail-panel {
  position: relative;
  z-index: 1;
  background: rgba(18, 22, 32, 0.78);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06), 0 26rpx 76rpx rgba(0, 0, 0, 0.38);
}

.top-panel {
  padding: 24rpx;
  background:
    linear-gradient(135deg, rgba(215, 251, 82, 0.08), rgba(255, 255, 255, 0.055)),
    rgba(18, 22, 32, 0.78);
}

.top-row,
.card-head,
.detail-head,
.link-row,
.member-row,
.join-box,
.admin-wechat-box,
.contact-actions,
.seat-line {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
}

.top-row {
  align-items: flex-start;
}

.top-row > view,
.card-head > view,
.detail-head > view,
.join-box > view,
.admin-wechat-box > view,
.member-main,
.member-meta {
  min-width: 0;
}

.eyebrow,
.detail-kicker,
.muted,
.sub-title,
.room-name,
.capacity,
.metric-label,
.member-role,
.link-text,
.time {
  color: rgba(235, 242, 247, 0.72);
}

.eyebrow {
  display: block;
  color: #d7fb52;
  font-size: 22rpx;
  font-weight: 900;
  letter-spacing: 0;
  text-transform: uppercase;
  text-shadow: 0 0 22rpx rgba(215, 251, 82, 0.26);
}

.title {
  margin-top: 8rpx;
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.08;
}

.sub-title {
  display: none;
  margin-top: 10rpx;
  font-size: 22rpx;
  line-height: 1.4;
}

.icon-button,
.ops-button,
.detail-button,
.primary-action,
.more-action {
  margin: 0;
  padding: 0 16rpx;
  min-height: 44rpx;
  color: #08100b;
  font-size: 20rpx;
  font-weight: 900;
  line-height: 44rpx;
  background: linear-gradient(135deg, #e8ff82, #d7fb52);
  border-radius: 999rpx;
  box-shadow: 0 0 24rpx rgba(215, 251, 82, 0.18);
  transition: all 0.25s ease;
}

.ops-button {
  color: #d7fb52;
  background: rgba(215, 251, 82, 0.1);
  border: 1rpx solid rgba(215, 251, 82, 0.34);
  box-shadow: none;
}

.icon-button:active,
.ops-button:active,
.detail-button:active,
.primary-action:active,
.more-action:active,
.filter-tab:active,
.table-card:active {
  transform: scale(0.96);
}

.icon-button {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  min-width: 112rpx;
  min-height: 48rpx;
  line-height: 48rpx;
}

.refresh-icon {
  display: inline-block;
  font-size: 24rpx;
  line-height: 1;
}

.icon-button.refreshing .refresh-icon {
  animation: spin 0.8s linear infinite;
}

.metrics {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 12rpx;
  margin-top: 24rpx;
}

.metric {
  position: relative;
  min-height: 104rpx;
  padding: 18rpx 16rpx;
  overflow: hidden;
  background:
    linear-gradient(180deg, rgba(255, 255, 255, 0.082), rgba(255, 255, 255, 0.04)),
    rgba(8, 11, 16, 0.58);
  border: 1rpx solid rgba(255, 255, 255, 0.09);
  border-radius: 20rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.08), inset 0 -12rpx 28rpx rgba(0, 0, 0, 0.18), 0 16rpx 34rpx rgba(0, 0, 0, 0.22);
}

.metric.alert {
  background:
    linear-gradient(180deg, rgba(255, 145, 0, 0.2), rgba(255, 255, 255, 0.04)),
    rgba(8, 11, 16, 0.6);
  border-color: rgba(255, 145, 0, 0.28);
}

.metric-value,
.metric-label,
.table-no,
.room-name,
.seat-number,
.seat-label,
.member-name,
.member-role,
.member-wechat {
  display: block;
}

.metric-value {
  position: relative;
  z-index: 1;
  color: #ffffff;
  font-size: 38rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow: 0 8rpx 32rpx rgba(215, 251, 82, 0.14);
}

.metric.alert .metric-value {
  color: #ffb24a;
  text-shadow: 0 0 26rpx rgba(255, 145, 0, 0.24);
}

.metric-label {
  position: relative;
  z-index: 1;
  margin-top: 8rpx;
  font-size: 21rpx;
  font-weight: 800;
}

.filter-tabs {
  position: relative;
  z-index: 1;
  display: flex;
  gap: 10rpx;
  margin: 18rpx 0;
  padding-bottom: 4rpx;
  overflow: hidden;
  white-space: nowrap;
}

.filter-tab {
  flex: 1 1 0;
  min-width: 0;
  min-height: 58rpx;
  padding: 0 8rpx;
  color: #ffffff;
  font-size: 22rpx;
  line-height: 58rpx;
  background: rgba(255, 255, 255, 0.065);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: none;
}

.filter-tab.active {
  color: #08100b;
  background: linear-gradient(135deg, #e8ff82, #d7fb52);
  border-color: rgba(255, 255, 255, 0.2);
  box-shadow: 0 0 32rpx rgba(215, 251, 82, 0.24);
}

.ops-panel {
  position: relative;
  z-index: 1;
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-bottom: 18rpx;
}

.ops-card {
  padding: 20rpx;
  background: rgba(18, 22, 32, 0.76);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.05), 0 18rpx 50rpx rgba(0, 0, 0, 0.26);
}

.ops-head {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 16rpx;
}

.ops-title {
  display: block;
  margin-top: 4rpx;
  color: rgba(255, 255, 255, 0.94);
  font-size: 25rpx;
  font-weight: 900;
}

.create-form {
  display: flex;
  flex-direction: column;
  gap: 14rpx;
  margin-top: 16rpx;
}

.form-row {
  display: flex;
  gap: 12rpx;
}

.form-item {
  flex: 1;
  min-width: 0;
}

.form-item-small {
  flex: 0 0 136rpx;
}

.field-label {
  display: block;
  color: rgba(235, 242, 247, 0.72);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.2;
}

.ops-input {
  box-sizing: border-box;
  display: block;
  width: 100%;
  min-width: 0;
  min-height: 62rpx;
  margin-top: 8rpx;
  padding: 0 18rpx;
  color: #f7fbff;
  font-size: 23rpx;
  line-height: 62rpx;
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.14);
  border-radius: 16rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.05), 0 10rpx 24rpx rgba(0, 0, 0, 0.14);
}

.ops-input-control {
  height: 62rpx;
  min-height: 62rpx;
  color: #f7fbff;
  font-size: 23rpx;
  font-weight: 800;
  line-height: 62rpx;
}

.ops-placeholder {
  color: rgba(235, 242, 247, 0.52);
}

.content-grid {
  position: relative;
  z-index: 1;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
}

.table-list {
  height: auto;
  max-height: none;
  overflow: visible;
}

.table-card {
  margin-bottom: 16rpx;
  padding: 22rpx;
  transition: all 0.25s ease;
}

.table-card.selected {
  background:
    linear-gradient(135deg, rgba(215, 251, 82, 0.12), rgba(91, 212, 199, 0.055) 44%, rgba(255, 255, 255, 0.045)),
    rgba(18, 22, 32, 0.86);
  border-color: rgba(215, 251, 82, 0.74);
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.08), 0 24rpx 84rpx rgba(0, 0, 0, 0.46), 0 0 46rpx rgba(215, 251, 82, 0.18);
}

.table-no {
  color: #ffffff;
  font-size: 42rpx;
  font-weight: 900;
  line-height: 1.06;
  text-shadow: 0 8rpx 34rpx rgba(215, 251, 82, 0.12);
}

.room-name {
  margin-top: 6rpx;
  overflow: hidden;
  font-size: 24rpx;
  font-weight: 700;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.status-pill {
  flex: 0 0 auto;
  padding: 8rpx 14rpx;
  color: #a0aec0;
  font-size: 21rpx;
  font-weight: 900;
  background: rgba(160, 174, 192, 0.12);
  border: 1rpx solid rgba(160, 174, 192, 0.18);
  border-radius: 999rpx;
}

.status-pill.available {
  color: #38ff99;
  background: rgba(0, 230, 118, 0.13);
  border-color: rgba(0, 230, 118, 0.34);
  box-shadow: 0 0 24rpx rgba(0, 230, 118, 0.16);
}

.status-pill.full {
  color: #ff4b6f;
  background: rgba(255, 23, 68, 0.14);
  border-color: rgba(255, 23, 68, 0.36);
  box-shadow: 0 0 24rpx rgba(255, 23, 68, 0.18);
}

.status-pill.hot,
.status-pill.quiet {
  color: #ffb24a;
  background: rgba(255, 145, 0, 0.14);
  border-color: rgba(255, 145, 0, 0.36);
  box-shadow: 0 0 24rpx rgba(255, 145, 0, 0.18);
}

.card-main {
  display: grid;
  grid-template-columns: 92rpx 1fr;
  align-items: center;
  gap: 14rpx;
  margin-top: 20rpx;
}

.count {
  color: #d7fb52;
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
  text-shadow: 0 0 28rpx rgba(215, 251, 82, 0.18);
}

.capacity {
  font-size: 22rpx;
  font-weight: 800;
}

.head-name {
  display: block;
  margin-top: 5rpx;
  overflow: hidden;
  color: #ffffff;
  font-size: 29rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.activity {
  display: flex;
  grid-column: 1 / -1;
  align-items: center;
  justify-content: space-between;
  gap: 8rpx;
  color: rgba(235, 242, 247, 0.78);
  font-size: 22rpx;
  font-weight: 700;
}

.seat-line {
  flex-wrap: wrap;
  margin-top: 16rpx;
  padding: 12rpx;
  color: rgba(235, 242, 247, 0.78);
  font-size: 22rpx;
  font-weight: 700;
  background: rgba(255, 255, 255, 0.052);
  border: 1rpx solid rgba(255, 255, 255, 0.065);
  border-radius: 18rpx;
}

.seat-progress {
  flex-basis: 100%;
  position: relative;
  height: 14rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.09);
  border-radius: 999rpx;
}

.seat-progress-fill {
  position: relative;
  height: 100%;
  max-width: 100%;
  background: linear-gradient(90deg, #00e676 0%, #d7fb52 55%, #e2b263 100%);
  border-radius: inherit;
  box-shadow: 0 0 24rpx rgba(215, 251, 82, 0.34);
}

.attention-text {
  color: #ffb24a;
  text-shadow: 0 0 18rpx rgba(255, 145, 0, 0.2);
}

.avatars {
  display: flex;
  margin-top: 22rpx;
  padding-left: 12rpx;
}

.avatar {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  margin-left: -12rpx;
  box-sizing: border-box;
  color: #08100b;
  font-size: 20rpx;
  font-weight: 900;
  background: #7f8b96;
  border: 4rpx solid #121620;
  border-radius: 50%;
  box-shadow: 0 6rpx 14rpx rgba(0, 0, 0, 0.32);
}

.avatar.online {
  background: linear-gradient(135deg, #e8ff82, #d7fb52);
  box-shadow: 0 0 20rpx rgba(215, 251, 82, 0.22);
}

.avatar.large {
  flex: 0 0 auto;
  width: 72rpx;
  height: 72rpx;
  margin-left: 0;
  font-size: 25rpx;
}

.last-line {
  display: none;
  grid-template-columns: 1fr auto;
  gap: 14rpx;
  margin-top: 18rpx;
  color: rgba(226, 232, 240, 0.68);
  font-size: 23rpx;
  line-height: 1.45;
}

.last-line text:first-child,
.link-text {
  overflow: hidden;
  text-overflow: ellipsis;
}

.detail-panel {
  padding: 22rpx;
}

.detail-kicker {
  display: none;
  font-size: 22rpx;
}

.detail-title {
  margin-top: 6rpx;
  color: #ffffff;
  font-size: 34rpx;
  font-weight: 900;
}

.seat-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.seat-summary view {
  padding: 16rpx 10rpx;
  text-align: center;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 18rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.05);
}

.seat-number {
  color: #ffffff;
  font-size: 36rpx;
  font-weight: 900;
}

.seat-label {
  margin-top: 5rpx;
  color: rgba(235, 242, 247, 0.78);
  font-size: 21rpx;
  font-weight: 700;
}

.join-box,
.admin-wechat-box {
  align-items: center;
  flex-direction: row;
  margin-top: 16rpx;
  padding: 18rpx;
  background: rgba(215, 251, 82, 0.08);
  border: 1rpx solid rgba(215, 251, 82, 0.18);
  border-radius: 20rpx;
  box-shadow: inset 0 1rpx 0 rgba(255, 255, 255, 0.06);
}

.admin-wechat-box {
  margin-top: 16rpx;
  background: rgba(0, 230, 118, 0.08);
  border-color: rgba(0, 230, 118, 0.18);
}

.join-code,
.admin-wechat {
  margin-top: 6rpx;
  color: #ffffff;
  font-size: 32rpx;
  font-weight: 900;
  letter-spacing: 1rpx;
  word-break: break-all;
}

.join-actions {
  display: flex;
  flex-direction: row;
  flex: 0 0 auto;
  gap: 8rpx;
}

.detail-button {
  min-width: 92rpx;
  max-width: 112rpx;
  min-height: 42rpx;
  padding: 0 12rpx;
  font-size: 19rpx;
  line-height: 42rpx;
  color: #d7fb52;
  background: rgba(215, 251, 82, 0.1);
  border: 1rpx solid rgba(215, 251, 82, 0.36);
  box-shadow: none;
}

.copied {
  color: #38ff99;
  background: rgba(0, 230, 118, 0.14);
  border: 1rpx solid rgba(0, 230, 118, 0.28);
  box-shadow: 0 0 20rpx rgba(0, 230, 118, 0.12);
}

.link-row {
  align-items: center;
  flex-direction: row;
  margin-top: 16rpx;
  padding: 14rpx 0;
  border-bottom: 1rpx solid rgba(255, 255, 255, 0.08);
}

.link-text {
  min-width: 0;
  flex: 1;
  font-size: 21rpx;
  color: rgba(235, 242, 247, 0.7);
  word-break: break-all;
}

.section-title {
  margin-top: 24rpx;
  margin-bottom: 14rpx;
  color: #ffffff;
  font-size: 30rpx;
  font-weight: 900;
}

.member-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
}

.member-row {
  flex-direction: row;
  align-items: center;
  padding: 16rpx;
  background: rgba(255, 255, 255, 0.06);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  border-radius: 20rpx;
}

.member-main {
  display: flex;
  align-items: center;
  gap: 18rpx;
  min-width: 0;
}

.member-name {
  overflow: hidden;
  color: #ffffff;
  font-size: 26rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-role {
  margin-top: 3rpx;
  color: rgba(235, 242, 247, 0.78);
  font-size: 21rpx;
}

.member-wechat {
  margin-top: 5rpx;
  color: rgba(235, 242, 247, 0.82);
  font-size: 21rpx;
  font-weight: 700;
  word-break: break-all;
}

.contact-actions {
  flex: 0 0 auto;
  display: flex;
  flex-direction: column;
  flex-wrap: nowrap;
  justify-content: center;
  margin-top: 0;
  gap: 8rpx;
}

.contact-actions .primary-action,
.contact-actions .more-action {
  width: 96rpx;
  min-height: 42rpx;
  padding: 0;
  font-size: 18rpx;
  line-height: 42rpx;
}

.primary-action {
  color: #d7fb52;
  background: rgba(215, 251, 82, 0.1);
  border: 1rpx solid rgba(215, 251, 82, 0.32);
  box-shadow: none;
}

.more-action {
  color: rgba(255, 255, 255, 0.9);
  background: rgba(255, 255, 255, 0.08);
  border: 1rpx solid rgba(255, 255, 255, 0.08);
  box-shadow: none;
}

@keyframes spin {
  to {
    transform: rotate(360deg);
  }
}

@keyframes adminGlow {
  0%, 100% {
    opacity: 0.22;
    transform: scale(0.94);
  }

  50% {
    opacity: 0.38;
    transform: scale(1.08);
  }
}

@keyframes progressSheen {
  0% {
    transform: translateX(-100%);
  }

  100% {
    transform: translateX(100%);
  }
}

@media (min-width: 768px) {
  .admin-page {
    padding: 34rpx;
  }

  .content-grid {
    display: grid;
    grid-template-columns: 1.05fr 0.95fr;
    align-items: start;
  }

  .ops-panel {
    grid-template-columns: 0.85fr 1.15fr;
  }

  .card-main {
    grid-template-columns: 126rpx 1fr auto;
  }

  .activity {
    grid-column: auto;
    flex-direction: column;
    align-items: flex-end;
  }

  .seat-line {
    flex-wrap: nowrap;
  }

  .seat-progress {
    flex: 1;
    flex-basis: auto;
  }

  .join-box,
  .admin-wechat-box,
  .link-row,
  .member-row {
    flex-direction: row;
    align-items: center;
  }

  .join-actions {
    flex-direction: column;
  }

  .contact-actions {
    margin-top: 0;
  }

  .table-list {
    max-height: none;
  }

  .metrics {
    grid-template-columns: repeat(4, 1fr);
  }

  .member-list {
    grid-template-columns: 1fr 1fr;
  }
}

@media (max-width: 360px) {
  .card-main,
  .member-list {
    grid-template-columns: 1fr;
  }

  .activity {
    align-items: flex-start;
  }

  .join-box,
  .admin-wechat-box {
    flex-direction: column;
    align-items: stretch;
  }

  .member-row {
    flex-direction: row;
    align-items: center;
  }

  .join-actions {
    flex-direction: row;
  }

  .contact-actions .primary-action,
  .contact-actions .more-action {
    width: 88rpx;
    font-size: 17rpx;
  }
}
