.admin-page {
  --bg: #f4f7fb;
  --bg-soft: #edf3fa;
  --text-strong: #172235;
  --text: rgba(23, 34, 53, 0.84);
  --text-muted: rgba(23, 34, 53, 0.52);
  --panel: rgba(255, 255, 255, 0.88);
  --panel-strong: rgba(255, 255, 255, 0.96);
  --panel-soft: rgba(23, 34, 53, 0.045);
  --line: rgba(23, 34, 53, 0.08);
  --blue: #2f80ff;
  --green: #31c48d;
  --orange: #ffad32;
  --red: #ff5b68;
  --shadow: 0 18rpx 54rpx rgba(51, 71, 102, 0.12);
  --shadow-soft: 0 10rpx 28rpx rgba(51, 71, 102, 0.08);
  --motion-fast: 140ms;
  --motion-base: 220ms;
  --motion-slow: 320ms;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-soft: cubic-bezier(0.22, 1, 0.36, 1);
  --press-scale: 0.972;
  display: flex;
  flex-direction: column;
  gap: 18rpx;
  min-height: 100vh;
  padding: 20rpx 22rpx 56rpx;
  box-sizing: border-box;
  overflow-x: hidden;
  color: var(--text);
  background:
    radial-gradient(circle at 18% 0%, rgba(47, 128, 255, 0.16), transparent 34%),
    radial-gradient(circle at 90% 8%, rgba(49, 196, 141, 0.13), transparent 30%),
    linear-gradient(180deg, #f8fbff 0%, #edf3fa 100%);
}

.admin-page.theme-dark {
  --bg: #111827;
  --bg-soft: #182235;
  --text-strong: #f4f7fb;
  --text: rgba(244, 247, 251, 0.84);
  --text-muted: rgba(244, 247, 251, 0.52);
  --panel: rgba(28, 38, 57, 0.88);
  --panel-strong: rgba(38, 50, 74, 0.96);
  --panel-soft: rgba(244, 247, 251, 0.06);
  --line: rgba(244, 247, 251, 0.1);
  --blue: #65a6ff;
  --green: #54d69e;
  --orange: #ffc15a;
  --red: #ff7280;
  --shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.28);
  --shadow-soft: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
  background:
    radial-gradient(circle at 18% 0%, rgba(101, 166, 255, 0.18), transparent 34%),
    radial-gradient(circle at 90% 8%, rgba(84, 214, 158, 0.12), transparent 30%),
    linear-gradient(180deg, #121b2b 0%, #0e1422 100%);
}

.ambient {
  display: none;
}

.top-panel {
  position: relative;
  order: 1;
  padding: 22rpx;
  margin-bottom: 0;
  animation: adminRise var(--motion-slow) var(--ease-soft) both;
}

.filter-tabs {
  order: 2;
  display: flex;
  gap: 10rpx;
  margin: 0;
  padding: 2rpx 2rpx 8rpx;
  overflow-x: auto;
  white-space: nowrap;
}

.content-grid {
  order: 3;
  display: grid;
  grid-template-columns: minmax(0, 0.96fr) minmax(0, 1.04fr);
  gap: 18rpx;
  align-items: start;
}

.ops-panel {
  order: 4;
  display: grid;
  grid-template-columns: 0.85fr 1.15fr;
  gap: 14rpx;
  margin-bottom: 0;
}

.reports-panel {
  order: 5;
}

.ended-panel {
  order: 6;
}

.top-panel,
.ops-card,
.reports-panel,
.ended-panel,
.table-card,
.detail-panel,
.invite-panel,
.report-card,
.ended-row,
.member-row,
.join-box,
.admin-wechat-box,
.seat-summary view,
.metric,
.invite-code-card,
.invite-link-box {
  color: var(--text);
  background: var(--panel);
  border: 1rpx solid var(--line);
  border-radius: 26rpx;
  box-shadow: var(--shadow);
}

.ops-card,
.reports-panel,
.ended-panel,
.detail-panel,
.table-card {
  padding: 20rpx;
  animation: adminRise 340ms var(--ease-soft) both;
}

.icon-button,
.ops-button,
.detail-button,
.panel-icon-button,
.primary-action,
.more-action,
.mini-action,
.filter-tab,
.report-tab,
.table-card,
.report-card,
.ended-row,
.member-row.contact-row,
.invite-action,
.invite-close,
.location-action,
.theme-toggle,
.metric,
.seat-summary view,
.join-box,
.admin-wechat-box {
  transform: translate3d(0, 0, 0);
  transition:
    transform var(--motion-fast) var(--ease-out),
    opacity var(--motion-base) var(--ease-soft),
    background-color var(--motion-base) var(--ease-soft),
    border-color var(--motion-base) var(--ease-soft),
    box-shadow var(--motion-base) var(--ease-soft);
}

.top-row,
.top-actions,
.metrics,
.card-head,
.detail-head,
.detail-actions,
.reports-head,
.report-top,
.report-actions,
.report-tabs,
.ops-head,
.field-title-row,
.member-row,
.member-main,
.contact-actions,
.join-box,
.admin-wechat-box,
.seat-line,
.invite-head,
.invite-actions {
  display: flex;
  align-items: center;
}

.top-row,
.card-head,
.detail-head,
.reports-head,
.report-top,
.ops-head,
.field-title-row,
.join-box,
.admin-wechat-box,
.invite-head {
  justify-content: space-between;
}

.top-row,
.ops-head,
.reports-head,
.detail-head,
.card-head {
  align-items: flex-start;
  gap: 16rpx;
}

.top-row > view:first-child,
.ops-head > view,
.card-head > view,
.detail-head > view,
.join-box > view,
.admin-wechat-box > view,
.member-meta,
.ended-copy,
.table-list,
.detail-panel {
  min-width: 0;
}

.top-actions,
.detail-actions,
.join-actions,
.contact-actions {
  flex: 0 0 auto;
}

.top-actions {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  gap: 10rpx;
}

.eyebrow,
.muted,
.sub-title,
.room-name,
.capacity,
.metric-label,
.member-role,
.member-wechat,
.report-meta,
.report-line,
.ended-meta,
.location-state,
.time,
.join-hint {
  color: var(--text-muted);
}

.eyebrow {
  display: block;
  color: var(--blue);
  font-size: 21rpx;
  font-weight: 900;
  letter-spacing: 0;
}

.title {
  margin-top: 8rpx;
  color: var(--text-strong);
  font-size: 40rpx;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.12;
}

.sub-title {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
}

.icon-button,
.ops-button,
.detail-button,
.panel-icon-button,
.primary-action,
.more-action,
.mini-action,
.invite-action,
.theme-toggle,
.filter-tab,
.report-tab,
.status-pill,
.report-status,
.ended-check {
  margin: 0;
  padding: 0;
  min-height: 0;
  text-align: center;
  border-radius: 999rpx;
}

.icon-button,
.filter-tab.active,
.report-tab.active,
.invite-action,
.detail-button:not(.muted-action),
.ops-button,
.primary-action,
.status-pill.available,
.report-status.pending,
.report-status.resolved,
.ended-check {
  color: #ffffff;
  background: linear-gradient(135deg, var(--blue), #667cff);
  border: 0;
  box-shadow: 0 10rpx 24rpx rgba(47, 128, 255, 0.2);
}

.admin-page.theme-dark .icon-button,
.admin-page.theme-dark .filter-tab.active,
.admin-page.theme-dark .report-tab.active,
.admin-page.theme-dark .invite-action,
.admin-page.theme-dark .detail-button:not(.muted-action),
.admin-page.theme-dark .ops-button,
.admin-page.theme-dark .primary-action,
.admin-page.theme-dark .status-pill.available,
.admin-page.theme-dark .report-status.pending,
.admin-page.theme-dark .report-status.resolved,
.admin-page.theme-dark .ended-check {
  color: #08111f;
}

.admin-page .top-actions .icon-button {
  color: var(--blue);
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
  box-shadow: none;
}

.icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  min-width: 112rpx;
  height: 52rpx;
  padding: 0 18rpx;
  font-size: 21rpx;
  font-weight: 900;
  line-height: 52rpx;
}

.icon-only {
  width: 52rpx;
  min-width: 52rpx;
  padding: 0;
}

.admin-page .theme-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  height: 52rpx;
  color: var(--text-strong);
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
  box-shadow: none;
}

.icon-button.refreshing {
  animation: spin 0.8s linear infinite;
}

.metrics {
  display: grid;
  grid-template-columns: repeat(4, minmax(0, 1fr));
  gap: 10rpx;
  margin-top: 22rpx;
}

.metric {
  min-height: 92rpx;
  padding: 16rpx 14rpx;
  background: var(--panel-soft);
  box-shadow: var(--shadow-soft);
}

.admin-page.theme-light .metric,
.admin-page.theme-light .join-box,
.admin-page.theme-light .admin-wechat-box,
.admin-page.theme-light .member-row.contact-row,
.admin-page.theme-light .seat-summary view,
.admin-page.theme-light .report-card,
.admin-page.theme-light .ended-row {
  background: rgba(255, 255, 255, 0.62);
}

.metric.alert {
  background: rgba(255, 173, 50, 0.12);
}

.metric-value,
.metric-label,
.table-no,
.room-name,
.seat-number,
.seat-label,
.member-name,
.member-role,
.member-wechat,
.report-reason,
.report-meta,
.report-line,
.report-message,
.report-empty,
.ended-title,
.ended-meta,
.ops-title,
.field-label,
.location-state,
.join-code,
.join-hint,
.admin-wechat,
.invite-scene,
.invite-error {
  display: block;
}

.metric-value {
  color: var(--text-strong);
  font-size: 34rpx;
  font-weight: 900;
  line-height: 1;
}

.metric.alert .metric-value {
  color: var(--orange);
}

.metric-label {
  margin-top: 8rpx;
  font-size: 21rpx;
  font-weight: 800;
}

.filter-tab,
.report-tab {
  flex: 0 0 auto;
  height: 56rpx;
  padding: 0 22rpx;
  color: var(--text-muted);
  font-size: 21rpx;
  font-weight: 900;
  line-height: 56rpx;
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
}

.ops-title {
  color: var(--text-strong);
  font-size: 26rpx;
  font-weight: 900;
}

.ops-icon-title,
.field-shell {
  display: flex;
  align-items: center;
}

.ops-icon-title {
  gap: 10rpx;
  color: var(--blue);
}

.ops-button,
.detail-button,
.primary-action,
.more-action,
.mini-action {
  height: 46rpx;
  padding: 0 16rpx;
  color: var(--blue);
  font-size: 19rpx;
  font-weight: 900;
  line-height: 46rpx;
  background: rgba(47, 128, 255, 0.1);
  border: 1rpx solid rgba(47, 128, 255, 0.16);
}

.ops-button {
  min-width: 50rpx;
  height: 50rpx;
  line-height: 50rpx;
  box-sizing: border-box;
}

.ops-button.icon-submit {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  min-width: 52rpx;
  height: 52rpx;
  padding: 0;
  color: var(--blue);
  background: rgba(47, 128, 255, 0.1);
  border: 1rpx solid rgba(47, 128, 255, 0.14);
  box-shadow: none;
}

.ops-button.icon-submit.loading {
  opacity: 0.55;
  pointer-events: none;
}

.detail-button {
  min-width: 132rpx;
  height: 48rpx;
  padding: 0 18rpx;
  line-height: 48rpx;
}

.detail-button.icon-detail-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 58rpx;
  min-width: 58rpx;
  padding: 0;
}

.panel-icon-button {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 52rpx;
  min-width: 52rpx;
  height: 52rpx;
  padding: 0;
  box-sizing: border-box;
  color: var(--blue);
  background: rgba(47, 128, 255, 0.1);
  border: 1rpx solid rgba(47, 128, 255, 0.16);
  border-radius: 50%;
  box-shadow: none;
}

.panel-icon-button.danger {
  color: var(--red);
  background: rgba(255, 91, 104, 0.1);
  border-color: rgba(255, 91, 104, 0.18);
}

.panel-icon-button.loading {
  opacity: 0.55;
  pointer-events: none;
}

.detail-button.muted-action,
.panel-icon-button.muted-action,
.more-action,
.mini-action.muted-action,
.invite-action.secondary {
  color: var(--blue);
  background: rgba(47, 128, 255, 0.1);
  border: 1rpx solid rgba(47, 128, 255, 0.16);
  box-shadow: none;
}

.mini-action.danger {
  color: var(--red);
  background: rgba(255, 91, 104, 0.12);
  border: 1rpx solid rgba(255, 91, 104, 0.18);
  box-shadow: none;
}

.copied,
.detail-button.copied,
.panel-icon-button.copied,
.ops-button.copied,
.primary-action.copied {
  color: #ffffff;
  background: linear-gradient(135deg, var(--green), #20b7a7);
}

.admin-page.theme-dark .copied,
.admin-page.theme-dark .detail-button.copied,
.admin-page.theme-dark .panel-icon-button.copied,
.admin-page.theme-dark .ops-button.copied,
.admin-page.theme-dark .primary-action.copied {
  color: #08111f;
}

.create-form {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
  margin-top: 16rpx;
}

.form-row {
  display: flex;
  gap: 12rpx;
}

.form-item {
  flex: 1;
  min-width: 0;
}

.form-item-small {
  flex: 0 0 154rpx;
}

.field-label {
  color: var(--text-muted);
  font-size: 21rpx;
  font-weight: 800;
}

.ops-input {
  box-sizing: border-box;
  width: 100%;
  height: 60rpx;
  margin-top: 0;
  padding: 0;
  color: var(--text-strong);
  font-size: 23rpx;
  font-weight: 800;
  background: transparent;
  border: 0;
  border-radius: 0;
}

.ops-input-control {
  color: var(--text-strong);
  font-size: 23rpx;
  font-weight: 800;
  line-height: 60rpx;
}

.admin-page .ops-input .t-input,
.admin-page .ops-input .t-input__wrap,
.admin-page .ops-input .t-input__content {
  min-height: 60rpx;
  padding: 0;
  background: transparent;
  border: 0;
}

.admin-page .ops-input .t-input__wrap {
  align-items: center;
}

.ops-placeholder {
  color: var(--text-muted);
}

.field-shell {
  gap: 12rpx;
  min-height: 64rpx;
  padding: 0 12rpx;
  color: var(--text-muted);
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
  border-radius: 18rpx;
  box-sizing: border-box;
}

.field-shell .ops-input {
  flex: 1;
  min-width: 0;
}

.ops-card > .ops-input {
  margin-top: 14rpx;
  padding: 0 14rpx;
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
  border-radius: 18rpx;
}

.address-shell {
  padding-right: 8rpx;
}

.location-action {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 48rpx;
  min-width: 48rpx;
  height: 48rpx;
  padding: 0;
  color: var(--blue);
  background: rgba(47, 128, 255, 0.1);
  border-radius: 50%;
}

.location-state {
  margin-top: 8rpx;
  font-size: 20rpx;
  line-height: 1.35;
}

.report-tabs {
  gap: 10rpx;
  margin-top: 16rpx;
}

.report-list,
.ended-list,
.member-list {
  display: grid;
  grid-template-columns: 1fr;
  gap: 14rpx;
  margin-top: 16rpx;
}

.report-card,
.ended-row,
.member-row.contact-row,
.join-box,
.admin-wechat-box,
.seat-summary view {
  background: var(--panel-soft);
  box-shadow: var(--shadow-soft);
}

.report-card,
.ended-row,
.member-row {
  padding: 16rpx;
}

.report-reason,
.ended-title,
.member-name,
.table-no,
.detail-title,
.join-code,
.admin-wechat,
.head-name {
  color: var(--text-strong);
  font-weight: 900;
}

.report-reason,
.ended-title,
.member-name {
  font-size: 25rpx;
}

.report-meta,
.report-line,
.ended-meta,
.member-role,
.member-wechat {
  margin-top: 6rpx;
  font-size: 21rpx;
}

.report-status,
.status-pill {
  flex: 0 0 auto;
  padding: 7rpx 14rpx;
  color: var(--text-muted);
  font-size: 19rpx;
  font-weight: 900;
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
}

.status-pill.available,
.report-status.pending {
  background: linear-gradient(135deg, var(--green), #20b7a7);
}

.status-pill.full {
  color: #172235;
  background: linear-gradient(135deg, var(--orange), #ff8e6d);
  border: 0;
}

.status-pill.ended,
.report-status.rejected {
  color: var(--text-muted);
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
  box-shadow: none;
}

.report-message {
  margin-top: 10rpx;
  padding: 12rpx;
  color: var(--text);
  font-size: 22rpx;
  line-height: 1.45;
  background: var(--panel-soft);
  border-radius: 16rpx;
}

.report-actions {
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 14rpx;
}

.report-empty {
  margin-top: 16rpx;
  padding: 20rpx;
  color: var(--text-muted);
  font-size: 22rpx;
  text-align: center;
  background: var(--panel-soft);
  border-radius: 18rpx;
}

.ended-row {
  gap: 14rpx;
}

.ended-row.selected {
  border-color: rgba(47, 128, 255, 0.38);
  background: rgba(47, 128, 255, 0.1);
}

.ended-check {
  flex: 0 0 auto;
  width: 36rpx;
  height: 36rpx;
  font-size: 22rpx;
  font-weight: 900;
  line-height: 36rpx;
}

.ended-title,
.ended-meta,
.room-name,
.head-name,
.member-name {
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.table-card {
  margin-bottom: 14rpx;
}

.table-card.selected {
  transform: translate3d(0, -2rpx, 0);
  background: var(--panel-strong);
  border-color: rgba(47, 128, 255, 0.28);
  box-shadow: 0 18rpx 54rpx rgba(47, 128, 255, 0.16);
}

.table-no {
  display: block;
  font-size: 30rpx;
  line-height: 1.16;
}

.room-name {
  margin-top: 6rpx;
  font-size: 24rpx;
  font-weight: 800;
}

.card-main {
  display: grid;
  grid-template-columns: 88rpx minmax(0, 1fr);
  gap: 14rpx;
  align-items: center;
  margin-top: 18rpx;
}

.count {
  color: var(--blue);
  font-size: 44rpx;
  font-weight: 900;
  line-height: 1;
}

.capacity {
  font-size: 22rpx;
  font-weight: 800;
}

.head-name {
  display: block;
  margin-top: 5rpx;
  font-size: 28rpx;
}

.activity {
  display: flex;
  grid-column: 1 / -1;
  gap: 16rpx;
  justify-content: space-between;
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 800;
}

.seat-line {
  flex-wrap: wrap;
  gap: 12rpx;
  margin-top: 16rpx;
  padding: 12rpx;
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 800;
  background: var(--panel-soft);
  border-radius: 18rpx;
}

.seat-progress {
  flex-basis: 100%;
  height: 12rpx;
  overflow: hidden;
  background: rgba(23, 34, 53, 0.08);
  border-radius: 999rpx;
}

.admin-page.theme-dark .seat-progress {
  background: rgba(244, 247, 251, 0.1);
}

.seat-progress-fill {
  width: 100%;
  height: 100%;
  background: linear-gradient(90deg, var(--blue), var(--green));
  border-radius: inherit;
  transform-origin: left center;
  transition: transform 320ms var(--ease-out);
}

.attention-text {
  color: var(--orange);
}

.avatars {
  display: flex;
  margin-top: 20rpx;
  padding-left: 10rpx;
}

.avatar {
  width: 52rpx;
  height: 52rpx;
  margin-left: -10rpx;
  color: #ffffff;
  font-size: 20rpx;
  font-weight: 900;
  overflow: hidden;
  border-radius: 50%;
  box-shadow: 0 8rpx 18rpx rgba(0, 0, 0, 0.14);
}

.avatar.online {
  box-shadow: 0 0 0 3rpx rgba(84, 214, 158, 0.45), 0 8rpx 18rpx rgba(0, 0, 0, 0.16);
}

.avatar.large {
  width: 72rpx;
  height: 72rpx;
  margin-left: 0;
  font-size: 28rpx;
  border-radius: 50%;
}

.last-line,
.detail-kicker {
  display: none;
}

.detail-title {
  max-width: 330rpx;
  font-size: 32rpx;
  line-height: 1.18;
}

.detail-actions {
  align-items: center;
  gap: 8rpx;
}

.seat-summary {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 10rpx;
  margin-top: 18rpx;
}

.seat-summary view {
  padding: 16rpx 10rpx;
  text-align: center;
}

.seat-number {
  color: var(--text-strong);
  font-size: 34rpx;
  font-weight: 900;
}

.seat-label {
  margin-top: 5rpx;
  color: var(--text-muted);
  font-size: 21rpx;
  font-weight: 800;
}

.join-box,
.admin-wechat-box {
  align-items: center;
  justify-content: space-between;
  gap: 14rpx;
  margin-top: 16rpx;
  padding: 16rpx 18rpx;
}

.join-code,
.admin-wechat {
  margin-top: 6rpx;
  font-family: -apple-system, BlinkMacSystemFont, "PingFang SC", "Helvetica Neue", Arial, sans-serif;
  font-size: 27rpx;
  word-break: break-all;
}

.join-hint {
  margin-top: 6rpx;
  font-size: 21rpx;
  line-height: 1.35;
}

.join-actions {
  display: flex;
  gap: 10rpx;
  min-width: 114rpx;
}

.section-title {
  margin-top: 24rpx;
  margin-bottom: 14rpx;
  color: var(--text-strong);
  font-size: 30rpx;
  font-weight: 900;
}

.member-row {
  align-items: flex-start;
  justify-content: space-between;
  gap: 16rpx;
}

.member-main {
  flex: 1;
  gap: 16rpx;
  min-width: 0;
}

.member-meta {
  flex: 1;
}

.member-status-icons {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  gap: 8rpx;
  height: 32rpx;
  margin-top: 6rpx;
  white-space: nowrap;
}

.status-dot {
  flex: 0 0 auto;
  width: 16rpx;
  height: 16rpx;
  background: #9aa4b2;
  border-radius: 50%;
}

.status-dot.online {
  background: var(--green);
}

.status-icon {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 30rpx;
  height: 30rpx;
  color: var(--text-muted);
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
  border-radius: 50%;
}

.status-icon.seated {
  color: var(--green);
  background: rgba(49, 196, 141, 0.12);
  border-color: rgba(49, 196, 141, 0.22);
}

.status-icon.ghost {
  color: var(--orange);
  background: rgba(255, 173, 50, 0.12);
  border-color: rgba(255, 173, 50, 0.2);
}

.status-icon.male {
  color: #2f80ff;
  background: rgba(47, 128, 255, 0.1);
  border-color: rgba(47, 128, 255, 0.18);
}

.status-icon.female {
  color: #ec5f9d;
  background: rgba(236, 95, 157, 0.1);
  border-color: rgba(236, 95, 157, 0.18);
}

.status-icon.head {
  color: var(--blue);
}

.ban-tag {
  display: inline-block;
  margin-top: 6rpx;
  padding: 4rpx 10rpx;
  color: var(--red);
  font-size: 18rpx;
  font-weight: 900;
  background: rgba(255, 91, 104, 0.1);
  border-radius: 999rpx;
}

.contact-actions {
  align-items: stretch;
  flex-direction: column;
  gap: 8rpx;
}

.contact-actions .primary-action,
.contact-actions .more-action {
  width: 104rpx;
  height: 42rpx;
  padding: 0;
  font-size: 18rpx;
  line-height: 42rpx;
}

.invite-mask {
  position: fixed;
  inset: 0;
  z-index: 20;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 38rpx;
  box-sizing: border-box;
  background: rgba(15, 23, 42, 0.42);
  animation: adminFadeIn var(--motion-base) var(--ease-soft) both;
}

.admin-page.theme-dark .invite-mask {
  background: rgba(3, 7, 18, 0.66);
}

.invite-panel {
  width: 100%;
  max-width: 640rpx;
  padding: 28rpx;
  box-sizing: border-box;
  background: var(--panel-strong);
  animation: adminSheetIn 260ms var(--ease-out) both;
}

.invite-title {
  margin-top: 6rpx;
  color: var(--text-strong);
  font-size: 30rpx;
  font-weight: 900;
}

.invite-close {
  flex: 0 0 auto;
  width: 56rpx;
  height: 56rpx;
  color: var(--text-muted);
  font-size: 38rpx;
  line-height: 56rpx;
  text-align: center;
  background: var(--panel-soft);
  border-radius: 50%;
}

.invite-code-card {
  margin-top: 24rpx;
  padding: 24rpx;
  text-align: center;
  background: var(--panel-soft);
  box-shadow: var(--shadow-soft);
}

.invite-qrcode-box {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 320rpx;
  height: 320rpx;
  margin: 0 auto;
  overflow: hidden;
  background: #ffffff;
  border: 1rpx solid var(--line);
  border-radius: 24rpx;
}

.invite-qrcode {
  width: 100%;
  height: 100%;
}

.invite-qrcode-placeholder {
  color: rgba(23, 34, 53, 0.54);
  font-size: 25rpx;
  font-weight: 900;
}

.invite-scene {
  margin-top: 18rpx;
  color: var(--blue);
  font-size: 28rpx;
  font-weight: 900;
}

.invite-error {
  margin-top: 10rpx;
  color: var(--orange);
  font-size: 22rpx;
  line-height: 1.4;
}

.invite-link-box {
  margin-top: 18rpx;
  padding: 16rpx 18rpx;
  color: var(--text-muted);
  font-size: 22rpx;
  line-height: 1.45;
  word-break: break-all;
  background: var(--panel-soft);
}

.invite-actions {
  display: grid;
  grid-template-columns: 1fr 1fr;
  gap: 12rpx;
  margin-top: 20rpx;
}

.invite-action {
  height: 72rpx;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 72rpx;
}

.icon-button:active,
.ops-button:active,
.detail-button:active,
.primary-action:active,
.more-action:active,
.mini-action:active,
.filter-tab:active,
.table-card:active,
.report-tab:active,
.invite-action:active,
.ended-row:active {
  transform: scale(var(--press-scale));
}

@media (max-width: 767px) {
  .admin-page {
    gap: 16rpx;
    padding: 18rpx 18rpx 46rpx;
  }

  .top-row {
    flex-wrap: nowrap;
    padding-right: 118rpx;
  }

  .top-actions {
    width: auto;
    justify-content: flex-end;
  }

  .metrics {
    grid-template-columns: repeat(2, minmax(0, 1fr));
  }

  .content-grid,
  .ops-panel {
    grid-template-columns: 1fr;
  }

  .ops-panel {
    gap: 12rpx;
  }

  .join-box,
  .admin-wechat-box {
    align-items: stretch;
  }

  .join-actions {
    grid-template-columns: 1fr 1fr;
    min-width: 0;
  }

  .member-list {
    grid-template-columns: 1fr;
  }

  .invite-actions {
    grid-template-columns: 1fr;
  }
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes adminRise {
  from {
    opacity: 0;
    transform: translate3d(0, 14rpx, 0) scale(0.985);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes adminFadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes adminSheetIn {
  from {
    opacity: 0;
    transform: translate3d(0, 20rpx, 0) scale(0.975);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}
