<view class="room-page theme-{{theme}} {{canChat ? 'can-chat' : 'chat-locked'}}">
  <view class="ambient ambient-left"></view>
  <view class="ambient ambient-right"></view>

  <view class="status-bar"></view>

  <block wx:if="{{loading}}">
    <view class="loading-state">
      <view class="loader"></view>
      <text>正在进入主局</text>
    </view>
  </block>

  <block wx:elif="{{room}}">
    <scroll-view class="room-scroll" scroll-y enhanced show-scrollbar="{{false}}" scroll-into-view="{{chatScrollTarget}}" scroll-with-animation>
      <view class="hero">
        <view class="hero-topline">
          <text class="venue-chip">{{room.statusText}}</text>
          <view class="hero-actions">
            <text class="live-tag">{{room.liveTag}}</text>
            <view class="theme-toggle icon-button-tool" bindtap="toggleTheme" aria-label="切换主题">
              <t-icon name="{{theme === 'dark' ? 'moon' : 'sunny'}}" size="30rpx" />
            </view>
          </view>
        </view>
        <view class="hero-title-row">
          <view>
            <text class="hero-title">{{room.title}}</text>
          </view>
        </view>
        <view class="manager-contact">
          <view class="contact-symbol">
            <t-icon name="logo-wechat-stroke" size="28rpx" />
          </view>
          <view class="manager-contact-copy">
            <text class="contact-value">{{room.manager.wechatId}}</text>
          </view>
          <view class="contact-button icon-button-tool" bindtap="onCopyManagerWechat" aria-label="复制管理员微信">
            <t-icon name="copy" size="30rpx" />
          </view>
        </view>
        <view class="room-notify-strip" wx:if="{{profileReady && notifyReady && !adminMode}}" bindtap="requestMessageSubscription">
          <view>
            <text class="room-notify-title">通知栏消息</text>
            <text class="room-notify-copy">{{notifyEnabled ? '已开启，离开后也能收到同桌新消息' : '离开小程序后接收同桌新消息'}}</text>
          </view>
          <text class="room-notify-state">{{notifySaving ? '保存中' : notifyEnabled ? '已开启' : '开启'}}</text>
        </view>
        <view class="legal-strip">
          <text data-type="terms" bindtap="openLegal">用户协议</text>
          <text>/</text>
          <text data-type="privacy" bindtap="openLegal">隐私政策</text>
          <text>/</text>
          <text data-type="community" bindtap="openLegal">社区规范</text>
        </view>
      </view>

      <view class="info-band">
        <view class="info-block address-block">
          <view class="address-head">
            <view class="address-copy">
              <text class="primary">{{room.venue.address}}</text>
            </view>
            <view class="map-button" bindtap="openMap" aria-label="打开地图">
              <t-icon name="map-navigation" size="22rpx" />
            </view>
          </view>
        </view>
        <view class="info-grid">
          <view class="info-block">
            <text class="label">桌 / 房</text>
            <text class="primary">{{room.room.tableName}}</text>
            <text class="muted">{{room.room.seatStatusText}}</text>
          </view>
          <view class="info-block share-block">
            <view class="share-compact">
              <view class="share-copy">
                <text class="primary share-text">入局二维码</text>
                <text class="share-hint">扫码加入</text>
              </view>
              <view class="share-action icon-action {{sharingQrcode ? 'loading' : ''}}" bindtap="onShareRoomQrcode" aria-label="分享入局二维码">
                <t-icon name="qrcode" size="34rpx" />
              </view>
            </view>
          </view>
        </view>
      </view>

      <view class="section">
        <view class="section-head">
          <text class="section-title">成员</text>
          <text class="section-meta">{{room.members.length}} 人在线候场</text>
        </view>
        <scroll-view class="member-row" scroll-x enhanced show-scrollbar="{{false}}">
          <view class="member-card {{memberTransitionId === item.id ? 'status-updated' : ''}}" wx:for="{{room.members}}" wx:key="id" data-user-id="{{item.id}}" bindlongpress="onReportMember">
            <view class="avatar-wrap" data-url="{{item.avatar}}" data-user-id="{{item.id}}" bindtap="previewAvatar">
              <image wx:if="{{item.avatar}}" class="member-avatar" src="{{item.avatar}}" mode="aspectFill"></image>
              <view wx:else class="member-avatar avatar-fallback avatar-pixel avatar-{{item.generatedAvatar.type}}">
                <view wx:for="{{item.generatedAvatar.cells}}" wx:key="key" class="avatar-cell" style="left: {{item.x * item.generatedAvatar.step}}%; top: {{item.y * item.generatedAvatar.step}}%; width: {{item.generatedAvatar.step}}%; height: {{item.generatedAvatar.step}}%; background: {{item.color}};"></view>
              </view>
              <view wx:if="{{item.isHead || item.role === '局头'}}" class="head-badge">
                <t-icon name="flag" size="18rpx" />
              </view>
              <view class="online-dot {{item.online ? 'online' : ''}}"></view>
            </view>
            <text class="member-name">{{item.name}}</text>
            <view class="member-status-icons">
              <view wx:if="{{item.isHead || item.role === '局头'}}" class="status-icon head">
                <t-icon name="flag" size="18rpx" />
              </view>
              <view class="status-icon gender {{item.gender}}">
                <t-icon name="{{item.gender === 'male' ? 'gender-male' : item.gender === 'female' ? 'gender-female' : 'user-unknown'}}" size="20rpx" color="{{item.gender === 'male' ? '#2f80ff' : item.gender === 'female' ? '#ec5f9d' : '#9aa4b2'}}" />
              </view>
              <view class="status-icon {{item.seatStatus === 'seated' ? 'seated' : 'ghost'}}">
                <t-icon name="{{item.seatStatus === 'seated' ? 'check-circle' : 'user'}}" size="20rpx" />
              </view>
            </view>
          </view>
        </scroll-view>
      </view>

      <view class="section chat-section">
        <view class="section-head">
          <text class="section-title">房间小聊</text>
        </view>
        <view class="message-list">
          <view class="message {{item.isMine ? 'mine' : ''}} {{likedPulseId === item.id ? 'liked-pulse' : ''}}" wx:for="{{room.messages}}" wx:key="id" data-id="{{item.id}}" bindtap="onMessageTap" bindlongpress="onQuoteMessage">
            <view wx:if="{{likedPulseId === item.id}}" class="like-burst {{item.isMine ? 'mine' : ''}}">
              <view class="like-ring"></view>
              <view class="like-core">
                <t-icon name="heart-filled" size="34rpx" color="#ffffff" />
              </view>
              <view class="like-spark spark-1"></view>
              <view class="like-spark spark-2"></view>
              <view class="like-spark spark-3"></view>
              <view class="like-spark spark-4"></view>
              <view class="like-spark spark-5"></view>
              <view class="like-spark spark-6"></view>
            </view>
            <image wx:if="{{item.avatar}}" class="message-avatar" src="{{item.avatar}}" mode="aspectFill" data-url="{{item.avatar}}" data-user-id="{{item.senderId}}" bindtap="previewAvatar"></image>
            <view wx:else class="message-avatar avatar-fallback avatar-pixel avatar-{{item.generatedAvatar.type}}">
              <view wx:for="{{item.generatedAvatar.cells}}" wx:key="key" class="avatar-cell" style="left: {{item.x * item.generatedAvatar.step}}%; top: {{item.y * item.generatedAvatar.step}}%; width: {{item.generatedAvatar.step}}%; height: {{item.generatedAvatar.step}}%; background: {{item.color}};"></view>
            </view>
            <view class="message-body">
              <view class="message-meta">
                <text class="message-name">{{item.sender}}</text>
                <text class="message-time">{{item.time}}</text>
                <view wx:if="{{item.likeCount > 0}}" class="meta-like">
                  <t-icon name="heart-filled" size="20rpx" />
                  <text>{{item.likeCount}}</text>
                </view>
              </view>

              <view class="quote-card" wx:if="{{item.quote}}">
                <text class="quote-sender">{{item.quote.sender}}</text>
                <text class="quote-summary">{{item.quote.summary}}</text>
              </view>

              <view wx:if="{{item.type === 'text'}}" class="bubble text-bubble">
                <text>{{item.text}}</text>
              </view>

              <view wx:elif="{{item.type === 'voice'}}" class="bubble voice-bubble {{item.playing ? 'playing' : ''}}" data-id="{{item.id}}" bindtap="onPlayVoice">
                <view class="voice-bars">
                  <text></text>
                  <text></text>
                  <text></text>
                  <text></text>
                </view>
                <text class="voice-copy">{{item.playing ? '播放中' : '语音消息'}} {{item.duration}}</text>
              </view>

              <view wx:elif="{{item.type === 'photo'}}" class="photo-message">
                <view wx:if="{{item.flashExpired}}" class="flash-expired">
                  <view class="flash-expired-icon"><t-icon name="lock-off" size="42rpx" /></view>
                  <text class="flash-expired-copy">已销毁</text>
                  <text class="flash-expired-sub">闪照</text>
                </view>
                <image wx:elif="{{item.image}}" class="photo-shot" src="{{item.image}}" mode="widthFix" data-id="{{item.id}}" bindtap="previewMedia"></image>
                <view wx:else class="photo-placeholder">
                  <view class="flash-expired-icon"><t-icon name="image" size="42rpx" /></view>
                  <text class="flash-expired-copy">暂不可见</text>
                </view>
                <view class="photo-actions" wx:if="{{(item.isFlash && !item.flashExpired) || item.text}}">
                  <text>{{item.isFlash ? item.flashCountdownText : item.text}}</text>
                </view>
              </view>

              <view wx:elif="{{item.type === 'emoji'}}" class="emoji-message" data-id="{{item.id}}" bindtap="previewMedia">
                <image wx:if="{{item.image}}" class="emoji-shot" src="{{item.image}}" mode="aspectFit"></image>
                <text wx:elif="{{item.text}}" class="emoji-text">{{item.text}}</text>
                <view wx:else class="emoji-placeholder">表情暂不可见</view>
              </view>

              <view wx:elif="{{item.type === 'video'}}" class="photo-message video-message" data-id="{{item.id}}" bindtap="previewMedia">
                <video
                  wx:if="{{item.video}}"
                  class="video-shot"
                  src="{{item.video}}"
                  object-fit="contain"
                  controls="{{true}}"
                  show-center-play-btn="{{true}}"
                  enable-progress-gesture="{{true}}"
                ></video>
                <view wx:else class="video-shot">
                  <view class="video-play">
                    <t-icon name="play-circle" size="70rpx" />
                  </view>
                </view>
              </view>

              <view wx:else class="bubble text-bubble">
                <text>{{item.text || '消息暂无法展示'}}</text>
              </view>
            </view>
          </view>
        </view>
      </view>
      <view id="chat-bottom" class="chat-bottom-anchor"></view>
    </scroll-view>

    <view class="composer safe-bottom" wx:if="{{profileReady && canChat}}">
      <view class="voice-recording" wx:if="{{voiceRecording}}">
        <view class="voice-live">
          <view class="voice-bars">
            <text></text>
            <text></text>
            <text></text>
            <text></text>
          </view>
          <text>正在录音 {{voiceRecordSeconds}}''</text>
        </view>
        <view class="voice-action cancel" bindtap="cancelVoiceRecord">取消</view>
        <view class="voice-action finish" bindtap="finishVoiceRecord">完成</view>
      </view>

      <view class="voice-review" wx:elif="{{voiceReview}}">
        <view class="voice-live">
          <view class="voice-bars">
            <text></text>
            <text></text>
            <text></text>
            <text></text>
          </view>
          <text>语音 {{voiceReview.duration}}</text>
        </view>
        <view class="voice-action cancel" bindtap="discardVoiceReview">取消</view>
        <view class="voice-action finish" bindtap="sendVoiceReview">{{sending ? '...' : '发送'}}</view>
      </view>

      <view class="composer-quote" wx:if="{{quotedMessage}}">
        <view class="composer-quote-copy">
          <text class="quote-sender">引用 {{quotedMessage.sender}}</text>
          <text class="quote-summary">{{quotedMessage.summary}}</text>
        </view>
        <view class="quote-close" bindtap="clearQuote">×</view>
      </view>

        <view class="composer-row">
          <view class="composer-tool voice-mode-tool {{voiceInputMode ? 'active' : ''}}" bindtap="toggleVoiceInputMode" aria-label="{{voiceInputMode ? '切换键盘输入' : '切换语音输入'}}">
          <t-icon name="microphone" size="34rpx" />
        </view>
        <input
          wx:if="{{!voiceInputMode}}"
          class="chat-input"
          value="{{inputText}}"
          bindinput="onInput"
          bindfocus="onInputFocus"
          placeholder="说点今晚的安排"
          placeholder-class="input-placeholder"
          confirm-type="send"
          confirm-hold="{{true}}"
          cursor-spacing="24"
          maxlength="500"
          bindconfirm="onSendText"
        />
        <view wx:else class="voice-hold-button {{voiceRecording ? 'recording' : ''}}" bindtouchstart="onVoiceTouchStart" bindtouchend="onVoiceTouchEnd" bindtouchcancel="cancelVoiceRecord">
          {{voiceRecording ? '松开发送' : '按住说话'}}
        </view>
        <view class="composer-tool emoji-tool {{emojiPanelOpen ? 'active' : ''}}" bindtap="toggleEmojiPanel" aria-label="表情">
          <text>☺</text>
        </view>
        <view wx:if="{{inputText}}" class="composer-tool send-button" bindtap="onSendText" aria-label="发送消息">
          <text wx:if="{{sending}}">...</text>
          <t-icon wx:else name="send" size="34rpx" />
        </view>
        <view wx:else class="composer-tool plus-tool {{plusPanelOpen ? 'active' : ''}}" bindtap="togglePlusPanel" aria-label="更多发送选项">
          <t-icon name="add" size="34rpx" />
        </view>
      </view>
      <view class="emoji-panel" wx:if="{{emojiPanelOpen}}">
        <scroll-view class="emoji-tabs" scroll-x enhanced show-scrollbar="{{false}}">
          <view
            class="emoji-tab {{activeEmojiGroupKey === item.key ? 'active' : ''}}"
            wx:for="{{emojiGroups}}"
            wx:key="key"
            data-key="{{item.key}}"
            bindtap="onEmojiGroupTap"
          >
            <text>{{item.icon}}</text>
          </view>
        </scroll-view>
        <swiper class="emoji-swiper" current="{{emojiPageIndex}}" duration="180" bindchange="onEmojiSwiperChange">
          <swiper-item wx:for="{{emojiPages}}" wx:key="id" wx:for-item="page">
            <view class="emoji-grid">
              <view
                class="emoji-cell"
                wx:for="{{page.items}}"
                wx:key="id"
                wx:for-item="emoji"
                data-id="{{emoji.id}}"
                data-value="{{emoji.value}}"
                bindtap="onSendEmoji"
              >
                <text>{{emoji.value}}</text>
              </view>
            </view>
          </swiper-item>
        </swiper>
        <view class="emoji-dots" wx:if="{{emojiPages.length > 1}}">
          <view class="emoji-dot {{emojiPageIndex === index ? 'active' : ''}}" wx:for="{{emojiPages}}" wx:key="id"></view>
        </view>
      </view>
      <view class="plus-panel" wx:if="{{plusPanelOpen}}">
        <view class="plus-item" bindtap="onChoosePhoto">
          <view class="plus-icon"><t-icon name="image" size="34rpx" /></view>
          <text>图片/视频</text>
        </view>
        <view class="plus-item" bindtap="toggleFlash">
          <view class="plus-icon {{flashEnabled ? 'active' : ''}}"><t-icon name="flashlight" size="34rpx" /></view>
          <text>{{flashEnabled ? '闪照开' : '闪照关'}}</text>
        </view>
        <view class="plus-item" wx:if="{{flashEnabled}}">
          <view class="flash-options">
            <view class="flash-second {{flashSeconds === 5 ? 'active' : ''}}" data-seconds="5" bindtap="setFlashSeconds">5s</view>
            <view class="flash-second {{flashSeconds === 10 ? 'active' : ''}}" data-seconds="10" bindtap="setFlashSeconds">10s</view>
          </view>
          <text>闪照时长</text>
        </view>
      </view>
    </view>
    <view class="seat-tip-float" wx:if="{{profileReady && !canChat}}">占位请添加管理员</view>

    <view class="profile-mask" wx:if="{{(!profileReady || profileEditing) && !adminMode}}" catchtouchmove="noop">
      <view class="profile-panel">
        <view class="profile-close" wx:if="{{profileReady}}" bindtap="closeProfileEditor">×</view>
        <view class="profile-head">
          <view class="profile-heading">
            <text class="profile-kicker">{{profileReady ? '个人资料' : '首次进入'}}</text>
            <text class="profile-title">{{profileReady ? '修改头像和昵称' : '完善头像和昵称'}}</text>
          </view>
          <button class="avatar-picker" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
            <image wx:if="{{profileForm.avatarUrl}}" class="picked-avatar" src="{{profileForm.avatarUrl}}" mode="aspectFill" binderror="onProfileAvatarError"></image>
          </button>
        </view>
        <input class="profile-input" type="nickname" value="{{profileForm.nickName}}" bindinput="onNickNameInput" placeholder="输入昵称" placeholder-class="input-placeholder" />
        <view class="gender-tabs">
          <button
            wx:for="{{genderOptions}}"
            wx:key="key"
            class="gender-tab {{profileForm.gender === item.key ? 'active' : ''}}"
            data-gender="{{item.key}}"
            bindtap="onGenderTap"
          >{{item.label}}</button>
        </view>
        <view class="notify-row" wx:if="{{notifyReady && !profileReady}}">
          <view>
            <text class="notify-title">通知栏消息</text>
            <text class="notify-copy">{{notifyEnabled ? '已开启，新消息会进入微信通知栏' : '离开小程序后接收同桌新消息'}}</text>
          </view>
          <t-button t-class="notify-button {{notifyEnabled ? 'enabled' : ''}}" bindtap="requestMessageSubscription">
            {{notifySaving ? '保存中' : notifyEnabled ? '已开启' : '开启'}}
          </t-button>
        </view>
        <view class="agreement-row" wx:if="{{!profileReady}}" bindtap="toggleAgreement">
          <text class="agreement-check">{{profileForm.agreementAccepted && profileForm.ageConfirmed ? '✓' : ''}}</text>
          <view class="agreement-copy">
            <text>我已阅读并同意</text>
            <text class="legal-link" data-type="terms" catchtap="openLegal">《用户协议》</text>
            <text class="legal-link" data-type="privacy" catchtap="openLegal">《隐私政策》</text>
            <text class="legal-link" data-type="community" catchtap="openLegal">《社区规范》</text>
            <text>，并确认本人已满 18 周岁</text>
          </view>
        </view>
        <t-button
          t-class="profile-submit"
          bindtap="onSaveProfile"
          disabled="{{profileSaving || !profileForm.avatarUrl || !profileForm.nickName || (!profileReady && (!profileForm.agreementAccepted || !profileForm.ageConfirmed))}}"
          loading="{{profileSaving}}"
        >{{profileReady ? '保存资料' : '进入主局'}}</t-button>
      </view>
    </view>

    <view class="media-preview-mask" wx:if="{{mediaPreview.visible}}" catchtap="closeMediaPreview" catchtouchmove="noop">
      <movable-area class="media-preview-area" scale-area>
        <movable-view
          class="media-preview-view"
          direction="all"
          scale
          scale-min="1"
          scale-max="4"
          scale-value="{{mediaPreview.scale}}"
          x="{{mediaPreview.x}}"
          y="{{mediaPreview.y}}"
          bindscale="onMediaPreviewScale"
          catchtap="onMediaPreviewImageTap"
        >
          <image class="media-preview-image" src="{{mediaPreview.url}}" mode="aspectFit" catchtap="onMediaPreviewImageTap"></image>
        </movable-view>
      </movable-area>
      <view class="media-preview-close" catchtap="closeMediaPreview">×</view>
    </view>
  </block>

  <block wx:else>
    <view class="empty-state">
      <view class="loader"></view>
      <text>主局暂时没有数据</text>
    </view>
  </block>
</view>
