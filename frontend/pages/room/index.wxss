.room-page {
  --bg: #f4f7fb;
  --bg-soft: #edf3fa;
  --text-strong: #182230;
  --text: rgba(24, 34, 48, 0.84);
  --text-muted: rgba(24, 34, 48, 0.5);
  --panel: rgba(255, 255, 255, 0.86);
  --panel-strong: rgba(255, 255, 255, 0.95);
  --panel-soft: rgba(24, 34, 48, 0.045);
  --line: rgba(24, 34, 48, 0.08);
  --blue: #2f80ff;
  --green: #31c48d;
  --orange: #ffad32;
  --red: #ff5b68;
  --shadow: 0 18rpx 54rpx rgba(51, 71, 102, 0.12);
  --shadow-soft: 0 10rpx 28rpx rgba(51, 71, 102, 0.08);
  --motion-fast: 140ms;
  --motion-base: 220ms;
  --motion-slow: 320ms;
  --ease-out: cubic-bezier(0.16, 1, 0.3, 1);
  --ease-soft: cubic-bezier(0.22, 1, 0.36, 1);
  --press-scale: 0.965;
  position: relative;
  height: 100vh;
  min-height: 100vh;
  display: flex;
  flex-direction: column;
  overflow: hidden;
  color: var(--text);
  background:
    radial-gradient(circle at 18% 0%, rgba(47, 128, 255, 0.18), transparent 34%),
    radial-gradient(circle at 88% 8%, rgba(49, 196, 141, 0.13), transparent 30%),
    linear-gradient(180deg, #f8fbff 0%, #edf3fa 100%);
}

.room-page.theme-dark {
  --bg: #111827;
  --bg-soft: #182235;
  --text-strong: #f4f7fb;
  --text: rgba(244, 247, 251, 0.84);
  --text-muted: rgba(244, 247, 251, 0.52);
  --panel: rgba(28, 38, 57, 0.88);
  --panel-strong: rgba(38, 50, 74, 0.96);
  --panel-soft: rgba(244, 247, 251, 0.06);
  --line: rgba(244, 247, 251, 0.1);
  --blue: #65a6ff;
  --green: #54d69e;
  --orange: #ffc15a;
  --red: #ff7280;
  --shadow: 0 20rpx 60rpx rgba(0, 0, 0, 0.28);
  --shadow-soft: 0 12rpx 32rpx rgba(0, 0, 0, 0.2);
  background:
    radial-gradient(circle at 18% 0%, rgba(101, 166, 255, 0.18), transparent 34%),
    radial-gradient(circle at 88% 8%, rgba(84, 214, 158, 0.12), transparent 30%),
    linear-gradient(180deg, #121b2b 0%, #0e1422 100%);
}

.ambient {
  display: none;
}

.status-bar {
  flex: 0 0 44rpx;
  height: 44rpx;
}

.room-scroll {
  flex: 1;
  position: relative;
  z-index: 1;
  height: 0;
  min-height: 0;
  padding-bottom: calc(154rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.room-page.chat-locked .room-scroll {
  padding-bottom: calc(8rpx + env(safe-area-inset-bottom));
}

.hero,
.info-band,
.member-card,
.bubble,
.photo-message,
.emoji-message,
.profile-panel,
.quote-card,
.composer-quote,
.manager-contact,
.room-notify-strip,
.info-block,
.voice-recording,
.voice-review,
.notify-row,
.agreement-row {
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
}

.hero,
.info-band,
.member-card,
.profile-panel {
  background: var(--panel);
  box-shadow: var(--shadow);
}

.theme-toggle,
.contact-button,
.map-button,
.composer-tool,
.send-button,
.voice-action,
.voice-hold-button,
.flash-toggle,
.flash-second,
.gender-tab,
.profile-submit,
.notify-button,
.member-card,
.meta-like,
.share-action,
.plus-icon,
.quote-close,
.profile-close,
.media-preview-close,
.room-notify-strip,
.agreement-row,
.avatar-picker {
  transform: translate3d(0, 0, 0);
  transition:
    transform var(--motion-fast) var(--ease-out),
    opacity var(--motion-base) var(--ease-soft),
    background-color var(--motion-base) var(--ease-soft),
    border-color var(--motion-base) var(--ease-soft),
    box-shadow var(--motion-base) var(--ease-soft);
}

.hero {
  margin: 18rpx 20rpx 16rpx;
  padding: 24rpx;
  animation: iosRise var(--motion-slow) var(--ease-soft) both;
}

.hero-topline,
.hero-title-row,
.hero-actions,
.manager-contact,
.room-notify-strip,
.legal-strip,
.address-head,
.section-head,
.message-meta,
.photo-actions,
.composer-row,
.voice-recording,
.voice-review,
.composer-quote,
.profile-head,
.notify-row,
.gender-tabs,
.composer-options,
.share-actions {
  display: flex;
  align-items: center;
}

.hero-topline,
.hero-title-row,
.manager-contact,
.room-notify-strip,
.address-head,
.section-head,
.notify-row {
  justify-content: space-between;
}

.hero-actions {
  gap: 12rpx;
  justify-content: flex-end;
  min-width: 0;
}

.venue-chip,
.live-tag,
.room-notify-state,
.flash-second,
.flash-toggle,
.meta-like,
.contact-button,
.map-button,
.voice-action,
.composer-tool,
.send-button,
.notify-button,
.profile-submit,
.share-action {
  border-radius: 999rpx;
}

.venue-chip {
  padding: 9rpx 18rpx;
  color: #ffffff;
  font-size: 22rpx;
  font-weight: 900;
  background: linear-gradient(135deg, var(--green), #20b7a7);
  box-shadow: 0 10rpx 22rpx rgba(49, 196, 141, 0.2);
}

.live-tag {
  max-width: 330rpx;
  padding: 9rpx 16rpx;
  overflow: hidden;
  color: var(--text);
  font-size: 22rpx;
  font-weight: 800;
  text-overflow: ellipsis;
  white-space: nowrap;
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
}

.theme-toggle {
  background: var(--panel-soft);
  border-color: var(--line);
  box-shadow: none;
}

.hero-title {
  display: block;
  margin-top: 22rpx;
  color: var(--text-strong);
  font-size: 46rpx;
  font-weight: 900;
  letter-spacing: 0;
  line-height: 1.12;
}

.manager-contact {
  gap: 12rpx;
  margin-top: 18rpx;
  padding: 12rpx 12rpx 12rpx 14rpx;
  background: rgba(255, 255, 255, 0.52);
}

.room-page.theme-dark .manager-contact,
.room-page.theme-dark .room-notify-strip,
.room-page.theme-dark .info-block,
.room-page.theme-dark .quote-card,
.room-page.theme-dark .composer-quote,
.room-page.theme-dark .voice-recording,
.room-page.theme-dark .voice-review,
.room-page.theme-dark .notify-row,
.room-page.theme-dark .agreement-row {
  background: var(--panel-soft);
}

.manager-contact-copy,
.room-notify-strip > view,
.address-copy,
.composer-quote-copy,
.profile-heading {
  flex: 1;
  min-width: 0;
}

.contact-symbol {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 46rpx;
  height: 46rpx;
  color: var(--green);
  background: rgba(49, 196, 141, 0.1);
  border: 1rpx solid rgba(49, 196, 141, 0.18);
  border-radius: 50%;
}

.contact-label,
.label,
.profile-kicker {
  display: block;
  color: var(--text-muted);
  font-size: 21rpx;
  font-weight: 800;
}

.contact-value {
  display: block;
  overflow: hidden;
  color: var(--text-strong);
  font-family: ui-monospace, SFMono-Regular, Menlo, Consolas, monospace;
  font-size: 27rpx;
  font-weight: 900;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.contact-hint,
.room-notify-copy,
.muted,
.section-meta,
.member-role,
.message-time,
.notify-copy,
.agreement-copy {
  color: var(--text-muted);
}

.contact-hint {
  display: block;
  margin-top: 6rpx;
  font-size: 21rpx;
  line-height: 1.35;
}

.contact-button,
.map-button,
.send-button,
.notify-button,
.profile-submit,
.share-action {
  display: flex;
  align-items: center;
  justify-content: center;
  color: #ffffff;
  font-weight: 900;
  background: linear-gradient(135deg, var(--blue), #667cff);
  box-shadow: 0 10rpx 22rpx rgba(47, 128, 255, 0.2);
}

.contact-button {
  flex: 0 0 auto;
  width: 54rpx;
  height: 54rpx;
  font-size: 20rpx;
}

.room-notify-strip {
  gap: 18rpx;
  margin-top: 16rpx;
  padding: 18rpx;
  background: rgba(47, 128, 255, 0.08);
}

.room-notify-title,
.notify-title {
  display: block;
  color: var(--text-strong);
  font-size: 25rpx;
  font-weight: 900;
}

.room-notify-copy,
.notify-copy {
  display: block;
  margin-top: 6rpx;
  font-size: 22rpx;
  line-height: 1.35;
}

.room-notify-state {
  flex: 0 0 auto;
  padding: 9rpx 16rpx;
  color: #ffffff;
  font-size: 21rpx;
  font-weight: 900;
  background: linear-gradient(135deg, var(--blue), #667cff);
}

.legal-strip {
  gap: 12rpx;
  margin-top: 16rpx;
  color: var(--text-muted);
  font-size: 22rpx;
  font-weight: 800;
}

.legal-strip text:nth-child(odd),
.legal-link {
  color: var(--blue);
}

.info-band,
.section {
  margin: 0 20rpx 18rpx;
}

.info-band {
  padding: 12rpx;
  animation: iosRise 360ms 40ms var(--ease-soft) both;
}

.address-head {
  gap: 12rpx;
  min-height: 52rpx;
}

.map-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 40rpx;
  width: 40rpx;
  height: 40rpx;
  min-width: 40rpx;
  min-height: 40rpx;
  max-width: 40rpx;
  max-height: 40rpx;
  box-sizing: border-box;
  padding: 0;
  font-size: 16rpx;
  line-height: 40rpx;
  color: #31c48d;
  background: rgba(49, 196, 141, 0.12);
  border: 1rpx solid rgba(49, 196, 141, 0.24);
  border-radius: 50%;
  box-shadow: none;
}

.info-grid {
  display: flex;
  gap: 12rpx;
  margin-top: 12rpx;
}

.info-block {
  flex: 1;
  min-width: 0;
  padding: 14rpx 16rpx;
  background: rgba(255, 255, 255, 0.58);
  box-shadow: none;
}

.primary {
  display: block;
  max-height: 68rpx;
  overflow: hidden;
  color: var(--text-strong);
  font-size: 26rpx;
  font-weight: 850;
  line-height: 1.3;
  text-overflow: ellipsis;
  word-break: break-all;
}

.muted {
  display: block;
  margin-top: 8rpx;
  font-size: 22rpx;
}

.share-block {
  flex: 0.95;
  display: flex;
  align-items: center;
  min-height: 96rpx;
  padding: 12rpx 14rpx 12rpx 18rpx;
}

.share-compact {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 10rpx;
  width: 100%;
  min-height: 68rpx;
}

.share-copy {
  flex: 1;
  min-width: 0;
}

.share-text {
  max-width: none;
  font-size: 26rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.share-hint {
  display: block;
  margin-top: 4rpx;
  color: var(--text-muted);
  font-size: 20rpx;
  font-weight: 800;
  line-height: 1.2;
}

.share-actions {
  gap: 8rpx;
  margin-top: 10rpx;
}

.share-action {
  flex: 0 0 auto;
  width: 66rpx;
  height: 66rpx;
  min-height: 0;
  padding: 0;
  font-size: 20rpx;
  line-height: 66rpx;
  text-align: center;
  background: linear-gradient(135deg, var(--green), #20b7a7);
}

.share-action.secondary {
  color: var(--blue);
  background: rgba(47, 128, 255, 0.1);
  box-shadow: none;
}

.section-head {
  margin: 24rpx 6rpx 14rpx;
}

.section-title {
  display: block;
  color: var(--text-strong);
  font-size: 32rpx;
  font-weight: 900;
}

.section-meta {
  font-size: 22rpx;
}

.member-row {
  width: 100%;
  white-space: nowrap;
}

.member-card {
  display: inline-flex;
  flex-direction: column;
  align-items: center;
  width: 150rpx;
  min-height: 174rpx;
  margin-right: 14rpx;
  padding: 18rpx 12rpx;
  vertical-align: top;
  border-radius: 26rpx;
  animation: iosPop 260ms var(--ease-soft) both;
}

.member-card.status-updated {
  border-color: rgba(49, 196, 141, 0.32);
  box-shadow: 0 18rpx 54rpx rgba(49, 196, 141, 0.12);
  animation: statusGlow 620ms var(--ease-out) both;
}

.avatar-wrap {
  position: relative;
}

.member-avatar,
.message-avatar,
.avatar-picker,
.picked-avatar,
.avatar-fallback {
  border-radius: 22rpx;
}

.member-avatar {
  width: 76rpx;
  height: 76rpx;
}

.avatar-pixel {
  position: relative;
  overflow: hidden;
  background: linear-gradient(135deg, #eaf3ff, #ffffff);
  border: 1rpx solid var(--line);
}

.room-page.theme-dark .avatar-pixel {
  background: linear-gradient(135deg, #24324b, #1a2436);
}

.avatar-pixel::before {
  position: absolute;
  inset: 12%;
  content: "";
  background: rgba(255, 255, 255, 0.5);
  border-radius: 18rpx;
}

.avatar-cell {
  position: absolute;
  z-index: 1;
  border-radius: 1rpx;
}

.avatar-male {
  background: linear-gradient(135deg, #dcebff, #f8fbff);
}

.avatar-female {
  background: linear-gradient(135deg, #ffe8f2, #fff8fb);
}

.avatar-unknown {
  background: linear-gradient(135deg, #fff2c8, #f1fff3);
}

.online-dot {
  position: absolute;
  right: 0;
  bottom: 2rpx;
  width: 18rpx;
  height: 18rpx;
  background: #9aa4b2;
  border: 3rpx solid rgba(255, 255, 255, 0.92);
  border-radius: 50%;
}

.online-dot.online {
  background: var(--green);
  box-shadow: 0 0 0 4rpx rgba(84, 214, 158, 0.22);
}

.member-name {
  display: block;
  width: 100%;
  margin-top: 14rpx;
  overflow: hidden;
  color: var(--text-strong);
  font-size: 24rpx;
  font-weight: 850;
  text-align: center;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.member-role {
  display: none;
}

.member-status-icons {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  justify-content: center;
  gap: 6rpx;
  width: 100%;
  height: 30rpx;
  margin-top: 6rpx;
  white-space: nowrap;
}

.status-icon {
  flex: 0 0 auto;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 28rpx;
  height: 28rpx;
  color: var(--text-muted);
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
  border-radius: 50%;
}

.status-icon.seated {
  color: var(--green);
  background: rgba(49, 196, 141, 0.12);
  border-color: rgba(49, 196, 141, 0.22);
}

.status-icon.ghost {
  color: var(--orange);
  background: rgba(255, 173, 50, 0.12);
  border-color: rgba(255, 173, 50, 0.2);
}

.status-icon.male {
  color: #2f80ff;
  background: rgba(47, 128, 255, 0.1);
  border-color: rgba(47, 128, 255, 0.18);
}

.status-icon.female {
  color: #ec5f9d;
  background: rgba(236, 95, 157, 0.1);
  border-color: rgba(236, 95, 157, 0.18);
}

.chat-section {
  padding-bottom: 20rpx;
}

.message-list {
  padding: 4rpx 0 20rpx;
}

.chat-bottom-anchor {
  width: 100%;
  height: 2rpx;
}

.message {
  position: relative;
  display: flex;
  gap: 14rpx;
  margin-bottom: 24rpx;
  transform-origin: left center;
  animation: messageInLeft 260ms var(--ease-out) both;
}

.message.mine {
  flex-direction: row-reverse;
  transform-origin: right center;
  animation-name: messageInRight;
}

.message-avatar {
  flex: 0 0 auto;
  width: 66rpx;
  height: 66rpx;
}

.message-body {
  flex: 0 1 auto;
  min-width: 0;
  max-width: 560rpx;
}

.message.mine .message-body {
  display: flex;
  flex-direction: column;
  align-items: flex-end;
}

.message-meta {
  display: flex;
  align-items: center;
  flex-wrap: nowrap;
  gap: 12rpx;
  margin-bottom: 9rpx;
}

.message.mine .message-meta {
  flex-direction: row-reverse;
}

.message-name {
  display: block;
  color: var(--text-strong);
  font-size: 23rpx;
  font-weight: 850;
}

.message-time {
  font-size: 20rpx;
}

.meta-like {
  display: flex;
  flex-direction: row;
  flex-wrap: nowrap;
  align-items: center;
  gap: 4rpx;
  height: 34rpx;
  padding: 0 10rpx;
  color: var(--blue);
  font-size: 20rpx;
  font-weight: 900;
  line-height: 34rpx;
  white-space: nowrap;
  background: rgba(47, 128, 255, 0.09);
  border: 0;
}

.meta-like text {
  line-height: 34rpx;
}

.message.liked-pulse .meta-like {
  animation: likeCountPop 360ms var(--ease-out) both;
}

.like-burst {
  position: absolute;
  top: 34rpx;
  left: 96rpx;
  z-index: 4;
  width: 78rpx;
  height: 78rpx;
  pointer-events: none;
}

.like-burst.mine {
  right: 96rpx;
  left: auto;
}

.like-core,
.like-ring,
.like-spark {
  position: absolute;
  pointer-events: none;
}

.like-core {
  top: 14rpx;
  left: 14rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 50rpx;
  height: 50rpx;
  background: linear-gradient(135deg, #ff477e, #ff8a3d);
  border-radius: 50%;
  box-shadow: 0 14rpx 28rpx rgba(255, 71, 126, 0.28);
  animation: likeCorePop 460ms var(--ease-out) both;
}

.like-ring {
  inset: 8rpx;
  border: 4rpx solid rgba(255, 91, 138, 0.48);
  border-radius: 50%;
  animation: likeRing 460ms var(--ease-out) both;
}

.like-spark {
  top: 36rpx;
  left: 36rpx;
  width: 10rpx;
  height: 10rpx;
  background: #ff5b8a;
  border-radius: 50%;
  opacity: 0;
}

.spark-1 { background: #ff5b8a; animation: sparkOne 480ms var(--ease-out) both; }
.spark-2 { background: #ffad32; animation: sparkTwo 480ms var(--ease-out) both; }
.spark-3 { background: #31c48d; animation: sparkThree 480ms var(--ease-out) both; }
.spark-4 { background: #2f80ff; animation: sparkFour 480ms var(--ease-out) both; }
.spark-5 { background: #ec5f9d; animation: sparkFive 480ms var(--ease-out) both; }
.spark-6 { background: #8b5cf6; animation: sparkSix 480ms var(--ease-out) both; }

.quote-card,
.composer-quote {
  max-width: 520rpx;
  margin-bottom: 12rpx;
  padding: 12rpx 18rpx;
  overflow: hidden;
  color: var(--text-muted);
  font-size: 21rpx;
  background: rgba(255, 255, 255, 0.58);
  border: 1rpx solid rgba(255, 255, 255, 0.62);
  border-radius: 20rpx;
}

.quote-card {
  display: flex;
  flex-direction: column;
  gap: 6rpx;
  box-shadow: 0 10rpx 26rpx rgba(24, 34, 48, 0.06);
}

.room-page.theme-dark .quote-card {
  background: rgba(27, 38, 58, 0.76);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: 0 12rpx 30rpx rgba(0, 0, 0, 0.18);
}

.quote-sender,
.quote-summary {
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.quote-sender {
  color: var(--text-strong);
  font-weight: 900;
}

.bubble,
.photo-message,
.emoji-message {
  display: inline-flex;
  max-width: 520rpx;
  overflow: hidden;
  background: rgba(255, 255, 255, 0.9);
  border: 1rpx solid rgba(255, 255, 255, 0.64);
  border-radius: 30rpx 30rpx 30rpx 12rpx;
  box-shadow: 0 14rpx 34rpx rgba(24, 34, 48, 0.1);
  transform-origin: left bottom;
  animation: iosMessage 240ms var(--ease-out) both;
}

.room-page.theme-dark .bubble,
.room-page.theme-dark .photo-message,
.room-page.theme-dark .emoji-message {
  background: rgba(27, 38, 58, 0.92);
  border-color: rgba(255, 255, 255, 0.08);
  box-shadow: 0 18rpx 38rpx rgba(0, 0, 0, 0.22);
}

.message.mine .bubble {
  color: #17331f;
  background: #9eea6a;
  border-color: transparent;
  border-radius: 30rpx 12rpx 30rpx 30rpx;
  transform-origin: right bottom;
  box-shadow: 0 12rpx 28rpx rgba(79, 166, 72, 0.16);
}

.room-page.theme-dark .message.mine .bubble {
  color: #ffffff;
  background: #2f8f5b;
  box-shadow: 0 14rpx 32rpx rgba(0, 0, 0, 0.22);
}

.message.mine .photo-message,
.message.mine .emoji-message {
  border-radius: 30rpx 12rpx 30rpx 30rpx;
  transform-origin: right bottom;
}

.text-bubble {
  padding: 18rpx 22rpx;
  color: var(--text);
  font-size: 28rpx;
  line-height: 1.52;
  word-break: break-word;
}

.message.mine .text-bubble {
  color: #17331f;
}

.room-page.theme-dark .message.mine .text-bubble {
  color: #ffffff;
}

.voice-bubble {
  align-items: center;
  gap: 16rpx;
  min-width: 236rpx;
  padding: 20rpx 24rpx;
}

.voice-bubble.playing {
  border-color: rgba(49, 196, 141, 0.32);
  box-shadow: 0 16rpx 34rpx rgba(49, 196, 141, 0.14);
}

.voice-bars {
  display: flex;
  align-items: center;
  gap: 6rpx;
  height: 38rpx;
}

.voice-bars text {
  width: 7rpx;
  background: var(--blue);
  border-radius: 999rpx;
  transform-origin: center;
  animation: voiceBar 920ms var(--ease-soft) infinite;
}

.voice-bars text:nth-child(1) { height: 16rpx; }
.voice-bars text:nth-child(2) { height: 30rpx; animation-delay: 80ms; }
.voice-bars text:nth-child(3) { height: 38rpx; animation-delay: 160ms; }
.voice-bars text:nth-child(4) { height: 24rpx; animation-delay: 240ms; }

.voice-copy {
  color: var(--text);
  font-size: 24rpx;
  font-weight: 800;
}

.message.mine .voice-copy {
  color: #17331f;
}

.room-page.theme-dark .message.mine .voice-copy {
  color: #ffffff;
}

.message.mine .voice-bars text {
  background: #17331f;
}

.room-page.theme-dark .message.mine .voice-bars text {
  background: #ffffff;
}

.photo-message {
  flex-direction: column;
  background: transparent;
  border: 0;
  box-shadow: 0 16rpx 36rpx rgba(24, 34, 48, 0.12);
}

.photo-shot,
.video-shot {
  display: block;
  width: 520rpx;
  height: 310rpx;
  background: rgba(255, 255, 255, 0.54);
}

.room-page.theme-dark .photo-message {
  background: transparent;
  box-shadow: 0 18rpx 44rpx rgba(0, 0, 0, 0.28);
}

.room-page.theme-dark .photo-shot,
.room-page.theme-dark .video-shot {
  background: rgba(255, 255, 255, 0.08);
}

.emoji-message {
  align-items: center;
  justify-content: center;
  width: 220rpx;
  height: 220rpx;
  padding: 14rpx;
  border-radius: 32rpx;
}

.emoji-shot {
  width: 196rpx;
  height: 196rpx;
}

.emoji-placeholder,
.photo-placeholder {
  color: var(--text-muted);
  font-size: 24rpx;
  font-weight: 850;
}

.photo-placeholder,
.flash-expired {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
  width: 520rpx;
  height: 270rpx;
  box-sizing: border-box;
  background:
    linear-gradient(135deg, rgba(255, 255, 255, 0.86), rgba(244, 248, 252, 0.74));
  border: 1rpx solid rgba(255, 255, 255, 0.62);
}

.flash-expired {
  color: #d9485f;
  background:
    linear-gradient(135deg, rgba(255, 245, 247, 0.96), rgba(246, 249, 252, 0.86));
}

.room-page.theme-dark .photo-placeholder,
.room-page.theme-dark .flash-expired {
  background:
    linear-gradient(135deg, rgba(38, 50, 72, 0.94), rgba(25, 35, 54, 0.94));
  border-color: rgba(255, 255, 255, 0.08);
}

.flash-expired-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 76rpx;
  height: 76rpx;
  color: inherit;
  background: rgba(255, 255, 255, 0.76);
  border: 1rpx solid rgba(255, 255, 255, 0.8);
  border-radius: 50%;
  box-shadow: 0 10rpx 24rpx rgba(24, 34, 48, 0.08);
}

.room-page.theme-dark .flash-expired-icon {
  background: rgba(255, 255, 255, 0.08);
  border-color: rgba(255, 255, 255, 0.1);
  box-shadow: none;
}

.flash-expired-copy {
  color: var(--text-strong);
  font-size: 28rpx;
  font-weight: 900;
  line-height: 1.2;
}

.flash-expired-sub {
  color: var(--text-muted);
  font-size: 21rpx;
  font-weight: 800;
  line-height: 1.2;
}

.photo-actions {
  gap: 16rpx;
  width: 100%;
  padding: 15rpx 20rpx;
  color: var(--text);
  font-size: 23rpx;
  font-weight: 850;
  line-height: 1.42;
  background: rgba(255, 255, 255, 0.86);
  border-top: 1rpx solid rgba(24, 34, 48, 0.06);
}

.room-page.theme-dark .photo-actions {
  color: var(--text);
  background: rgba(27, 38, 58, 0.96);
  border-top-color: rgba(255, 255, 255, 0.08);
}

.composer {
  position: fixed;
  right: 0;
  bottom: 0;
  left: 0;
  z-index: 5;
  padding: 12rpx 18rpx calc(20rpx + env(safe-area-inset-bottom));
  background: transparent;
  border: 0;
  box-shadow: none;
  border-radius: 0;
  animation: composerDock 240ms var(--ease-out) both;
}

.composer-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
  width: 100%;
  min-width: 0;
  min-height: 104rpx;
  padding: 12rpx;
  box-sizing: border-box;
  background: var(--panel);
  border: 1rpx solid var(--line);
  border-radius: 38rpx;
  box-shadow: var(--shadow);
}

.composer-options {
  gap: 10rpx;
  margin-bottom: 12rpx;
}

.voice-recording,
.voice-review,
.composer-quote {
  gap: 12rpx;
  width: 100%;
  min-height: 68rpx;
  margin-bottom: 12rpx;
  padding: 10rpx 12rpx;
  background: transparent;
  border: 0;
  box-shadow: none;
  animation: iosPanelUp 220ms var(--ease-out) both;
}

.composer-quote {
  justify-content: space-between;
  min-height: 0;
}

.quote-close {
  flex: 0 0 auto;
  width: 44rpx;
  height: 44rpx;
  color: var(--text-muted);
  font-size: 32rpx;
  font-weight: 700;
  line-height: 44rpx;
  text-align: center;
  background: var(--panel-soft);
  border-radius: 50%;
}

.voice-live {
  flex: 1;
  display: flex;
  align-items: center;
  gap: 14rpx;
  min-width: 0;
  color: var(--text);
  font-size: 25rpx;
  font-weight: 850;
}

.voice-action {
  flex: 0 0 auto;
  min-width: 82rpx;
  height: 50rpx;
  padding: 0 18rpx;
  color: var(--text);
  font-size: 23rpx;
  font-weight: 900;
  line-height: 50rpx;
  text-align: center;
  background: var(--panel);
  border: 1rpx solid var(--line);
}

.voice-action.finish {
  color: #ffffff;
  background: linear-gradient(135deg, var(--green), #20b7a7);
}

.chat-input,
.profile-input {
  box-sizing: border-box;
  padding: 0 28rpx;
  color: var(--text-strong);
  font-size: 29rpx;
  background: var(--panel-strong);
  border: 1rpx solid var(--line);
}

.chat-input {
  flex: 1;
  min-width: 0;
  width: 0;
  height: 78rpx;
  line-height: 78rpx;
  border-radius: 28rpx;
  box-shadow: none;
}

.voice-hold-button {
  flex: 1;
  min-width: 0;
  height: 78rpx;
  box-sizing: border-box;
  color: var(--text);
  font-size: 28rpx;
  font-weight: 850;
  line-height: 78rpx;
  text-align: center;
  background: var(--panel-strong);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  box-shadow: none;
}

.voice-hold-button.recording {
  color: #ffffff;
  background: linear-gradient(135deg, var(--blue), #667cff);
  transform: scale(0.985);
  box-shadow: 0 12rpx 30rpx rgba(47, 128, 255, 0.24);
}

.profile-input {
  width: 100%;
  height: 84rpx;
  margin-top: 28rpx;
  border-radius: 22rpx;
}

.input-placeholder {
  color: var(--text-muted);
}

.composer-tool,
.send-button {
  display: flex;
  align-items: center;
  justify-content: center;
  flex: 0 0 auto;
  width: 76rpx;
  height: 76rpx;
  box-sizing: border-box;
  padding: 0;
  color: var(--text);
  font-size: 18rpx;
  text-align: center;
  background: var(--panel-strong);
  border: 1rpx solid var(--line);
  border-radius: 50%;
  box-shadow: none;
}

.send-button,
.voice-mode-tool.active,
.plus-tool.active {
  color: #ffffff;
  border: 0;
}

.send-button,
.voice-mode-tool.active,
.plus-tool.active {
  background: linear-gradient(135deg, var(--blue), #667cff);
}

.flash-toggle,
.flash-second,
.gender-tab {
  height: 48rpx;
  color: var(--text-muted);
  font-size: 21rpx;
  line-height: 48rpx;
  text-align: center;
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
}

.flash-toggle {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 10rpx;
  width: 118rpx;
}

.check-box {
  width: 26rpx;
  height: 26rpx;
  font-size: 18rpx;
  font-weight: 900;
  line-height: 26rpx;
  text-align: center;
  border: 2rpx solid currentColor;
  border-radius: 8rpx;
}

.flash-options {
  display: flex;
  gap: 10rpx;
}

.flash-second {
  width: 70rpx;
}

.flash-toggle.active,
.flash-second.active,
.gender-tab.active {
  color: #ffffff;
  font-weight: 900;
  background: linear-gradient(135deg, var(--green), #20b7a7);
  border-color: transparent;
}

.plus-panel {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 12rpx;
  margin-top: 12rpx;
  padding: 16rpx 12rpx 10rpx;
  background: var(--panel);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
  box-shadow: var(--shadow);
  animation: iosPanelUp 220ms var(--ease-out) both;
}

.plus-item {
  display: flex;
  flex-direction: column;
  align-items: center;
  gap: 8rpx;
  min-width: 0;
  color: var(--text-muted);
  font-size: 20rpx;
  font-weight: 800;
}

.plus-icon {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  box-sizing: border-box;
  color: var(--text);
  background: var(--panel-strong);
  border: 1rpx solid var(--line);
  border-radius: 20rpx;
  box-shadow: none;
}

.plus-icon.active {
  color: #ffffff;
  background: linear-gradient(135deg, var(--green), #20b7a7);
  border-color: transparent;
}

.plus-item .flash-options {
  display: flex;
  gap: 6rpx;
}

.plus-item .flash-second {
  width: 54rpx;
  height: 34rpx;
  font-size: 18rpx;
  line-height: 34rpx;
}

.seat-tip-float {
  position: fixed;
  bottom: calc(46rpx + env(safe-area-inset-bottom));
  left: 50%;
  z-index: 6;
  width: 240rpx;
  color: rgba(24, 34, 48, 0.32);
  font-size: 22rpx;
  font-weight: 700;
  line-height: 30rpx;
  text-align: center;
  pointer-events: none;
  background: transparent;
  border: 0;
  box-shadow: none;
  transform: translateX(-50%);
}

.room-page.theme-dark .seat-tip-float {
  color: rgba(244, 247, 251, 0.36);
}

.profile-mask {
  position: fixed;
  inset: 0;
  z-index: 10;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 112rpx 34rpx 72rpx;
  box-sizing: border-box;
  background: rgba(238, 243, 249, 0.72);
  animation: fadeIn var(--motion-base) var(--ease-soft) both;
}

.room-page.theme-dark .profile-mask {
  background: rgba(3, 7, 18, 0.66);
}

.profile-panel {
  position: relative;
  width: 100%;
  max-width: 650rpx;
  padding: 40rpx;
  border-radius: 34rpx;
  animation: sheetIn 260ms var(--ease-out) both;
}

.profile-close {
  position: absolute;
  top: 22rpx;
  right: 22rpx;
  z-index: 2;
  width: 54rpx;
  height: 54rpx;
  color: var(--text-muted);
  font-size: 38rpx;
  line-height: 54rpx;
  text-align: center;
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
  border-radius: 50%;
}

.profile-head {
  gap: 28rpx;
  min-height: 160rpx;
}

.profile-title {
  display: block;
  margin-top: 10rpx;
  color: var(--text-strong);
  font-size: 40rpx;
  font-weight: 900;
  line-height: 1.18;
}

.avatar-picker {
  flex: 0 0 144rpx;
  width: 144rpx;
  height: 144rpx;
  min-height: 0;
  margin: 0;
  padding: 0;
  overflow: hidden;
  background: var(--panel-soft);
  border: 1rpx solid var(--line);
  border-radius: 28rpx;
}

.picked-avatar {
  width: 100%;
  height: 100%;
}

.gender-tabs {
  gap: 10rpx;
  margin-top: 20rpx;
}

.gender-tab {
  flex: 1;
  min-height: 48rpx;
  margin: 0;
  padding: 0;
  border-radius: 999rpx;
}

.notify-row,
.agreement-row {
  gap: 16rpx;
  margin-top: 22rpx;
  padding: 18rpx;
  background: var(--panel-soft);
}

.agreement-row {
  display: flex;
  align-items: flex-start;
}

.agreement-check {
  flex: 0 0 36rpx;
  width: 36rpx;
  height: 36rpx;
  color: #ffffff;
  font-size: 24rpx;
  font-weight: 900;
  line-height: 36rpx;
  text-align: center;
  background: var(--green);
  border-radius: 10rpx;
}

.agreement-copy {
  flex: 1;
  min-width: 0;
  font-size: 22rpx;
  line-height: 1.56;
}

.notify-button {
  flex: 0 0 116rpx;
  width: 116rpx;
  height: 58rpx;
  min-height: 0;
  margin: 0;
  padding: 0;
  font-size: 23rpx;
  line-height: 58rpx;
}

.profile-submit {
  width: 100%;
  height: 86rpx;
  min-height: 0;
  margin-top: 26rpx;
  font-size: 27rpx;
  line-height: 86rpx;
}

.loading-state,
.empty-state {
  position: fixed;
  inset: 0;
  z-index: 2;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  gap: 24rpx;
  color: var(--text-muted);
  font-size: 26rpx;
}

.loader {
  width: 52rpx;
  height: 52rpx;
  border: 4rpx solid var(--line);
  border-top-color: var(--blue);
  border-radius: 50%;
  animation: spin 0.8s linear infinite;
}

.media-preview-mask {
  position: fixed;
  inset: 0;
  z-index: 30;
  background: rgba(9, 11, 18, 0.94);
  animation: fadeIn var(--motion-base) var(--ease-soft) both;
}

.media-preview-area,
.media-preview-view,
.media-preview-image {
  width: 100vw;
  height: 100vh;
}

.media-preview-view {
  display: flex;
  align-items: center;
  justify-content: center;
  animation: mediaZoom 260ms var(--ease-out) both;
}

.media-preview-close {
  position: fixed;
  top: calc(34rpx + env(safe-area-inset-top));
  right: 28rpx;
  z-index: 31;
  display: flex;
  align-items: center;
  justify-content: center;
  width: 64rpx;
  height: 64rpx;
  color: #ffffff;
  font-size: 42rpx;
  background: rgba(255, 255, 255, 0.14);
  border: 1rpx solid rgba(255, 255, 255, 0.18);
  border-radius: 50%;
}

.contact-button:active,
.map-button:active,
.composer-tool:active,
.send-button:active,
.voice-action:active,
.flash-toggle:active,
.flash-second:active,
.gender-tab:active,
.profile-submit:active,
.notify-button:active,
.member-card:active,
.meta-like:active,
.share-action:active {
  transform: scale(var(--press-scale));
}

@keyframes spin {
  to { transform: rotate(360deg); }
}

@keyframes iosRise {
  from {
    opacity: 0;
    transform: translate3d(0, 14rpx, 0) scale(0.985);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes iosPop {
  from {
    opacity: 0;
    transform: translate3d(0, 8rpx, 0) scale(0.975);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes iosMessage {
  from {
    opacity: 0;
    transform: translate3d(0, 6rpx, 0) scale(0.988);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes messageInLeft {
  from {
    opacity: 0;
    transform: translate3d(-10rpx, 10rpx, 0) scale(0.99);
  }

  72% {
    opacity: 1;
    transform: translate3d(1rpx, 0, 0) scale(1.001);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes messageInRight {
  from {
    opacity: 0;
    transform: translate3d(10rpx, 10rpx, 0) scale(0.99);
  }

  72% {
    opacity: 1;
    transform: translate3d(-1rpx, 0, 0) scale(1.001);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes likeCountPop {
  0% {
    transform: scale(0.86);
  }

  48% {
    transform: scale(1.08);
  }

  100% {
    transform: scale(1);
  }
}

@keyframes likeCorePop {
  0% {
    opacity: 0;
    transform: translate3d(0, 12rpx, 0) scale(0.42) rotate(-10deg);
  }

  42% {
    opacity: 1;
    transform: translate3d(0, -4rpx, 0) scale(1.04) rotate(4deg);
  }

  76% {
    opacity: 1;
    transform: translate3d(0, -18rpx, 0) scale(0.96) rotate(0deg);
  }

  100% {
    opacity: 0;
    transform: translate3d(0, -28rpx, 0) scale(0.86) rotate(0deg);
  }
}

@keyframes likeRing {
  0% {
    opacity: 0;
    transform: scale(0.28);
  }

  35% {
    opacity: 0.7;
  }

  100% {
    opacity: 0;
    transform: scale(1.28);
  }
}

@keyframes fadeIn {
  from { opacity: 0; }
  to { opacity: 1; }
}

@keyframes sheetIn {
  from {
    opacity: 0;
    transform: translate3d(0, 22rpx, 0) scale(0.975);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes iosPanelUp {
  from {
    opacity: 0;
    transform: translate3d(0, 12rpx, 0) scale(0.985);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0) scale(1);
  }
}

@keyframes composerDock {
  from {
    opacity: 0;
    transform: translate3d(0, 18rpx, 0);
  }

  to {
    opacity: 1;
    transform: translate3d(0, 0, 0);
  }
}

@keyframes mediaZoom {
  from {
    opacity: 0;
    transform: scale(0.985);
  }

  to {
    opacity: 1;
    transform: scale(1);
  }
}

@keyframes statusGlow {
  0% {
    transform: scale(0.985);
  }

  46% {
    transform: scale(1.015);
  }

  100% {
    transform: scale(1);
  }
}

@keyframes voiceBar {
  0%, 100% { transform: scaleY(0.7); opacity: 0.72; }
  50% { transform: scaleY(1); opacity: 1; }
}

@keyframes sparkOne {
  0% { opacity: 0; transform: translate3d(0, 0, 0) scale(0.4); }
  28% { opacity: 1; }
  100% { opacity: 0; transform: translate3d(-30rpx, -34rpx, 0) scale(0.9); }
}

@keyframes sparkTwo {
  0% { opacity: 0; transform: translate3d(0, 0, 0) scale(0.4); }
  28% { opacity: 1; }
  100% { opacity: 0; transform: translate3d(4rpx, -42rpx, 0) scale(0.78); }
}

@keyframes sparkThree {
  0% { opacity: 0; transform: translate3d(0, 0, 0) scale(0.4); }
  28% { opacity: 1; }
  100% { opacity: 0; transform: translate3d(34rpx, -28rpx, 0) scale(0.92); }
}

@keyframes sparkFour {
  0% { opacity: 0; transform: translate3d(0, 0, 0) scale(0.4); }
  28% { opacity: 1; }
  100% { opacity: 0; transform: translate3d(38rpx, 8rpx, 0) scale(0.78); }
}

@keyframes sparkFive {
  0% { opacity: 0; transform: translate3d(0, 0, 0) scale(0.4); }
  28% { opacity: 1; }
  100% { opacity: 0; transform: translate3d(-24rpx, 24rpx, 0) scale(0.82); }
}

@keyframes sparkSix {
  0% { opacity: 0; transform: translate3d(0, 0, 0) scale(0.4); }
  28% { opacity: 1; }
  100% { opacity: 0; transform: translate3d(-40rpx, -2rpx, 0) scale(0.74); }
}
