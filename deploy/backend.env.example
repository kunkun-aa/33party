APP_ENV=production
HOST=127.0.0.1
PORT=7892
PARTY_DB_PATH=/var/lib/33party/party.db
PUBLIC_API_BASE_URL=https://api.example.com
UPLOAD_DIR=/var/lib/33party/uploads
MAX_UPLOAD_BYTES=83886080
REQUIRE_ADMIN_AUTH=1
ADMIN_API_KEY=replace-with-a-long-random-admin-key
WECHAT_MINIPROGRAM_APPID=replace-with-mini-program-appid
WECHAT_MINIPROGRAM_SECRET=replace-with-mini-program-secret
WECHAT_MINIPROGRAM_ENV_VERSION=release
